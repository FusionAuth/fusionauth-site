---
import { getCollection } from "astro:content";
import Default from "./Default.astro";
import { sortArticle } from "/src/components/ArticleSort.js";
import ArticleNav from '/src/components/nav/ArticleNav.astro';
import Sidebar from '/src/components/Sidebar.astro';
import { getCollection } from 'astro:content';

const articlesCollection = await getCollection('articles');
const basePath = '/articles';

let { frontmatter, section } = Astro.props;
section = frontmatter.section ? frontmatter.section : section;

const openGraphImage = '/img/og/articles-developers-v1.png';
---
<Default {openGraphImage} {...Astro.props}>
  <ArticleNav slot="nav"/>
  <Sidebar slot="sideNav" {frontmatter} collection={articlesCollection} {basePath} />
  <slot/>
</Default>
