---
import Default from './Default.astro';
import DocsNav from '../components/nav/DocsNav.astro';
import Sidebar from 'src/components/Sidebar.astro';
import { Category } from '../tools/docs';

let { frontmatter, headings, navContext, noSideNav } = Astro.props;

const openGraphImage = '/img/og/docs-developers-v1.png'

const breadcrumbs = [];
const searchFilters: { [key: string]: string[] } = {
  environment: ['docs']
}
breadcrumbs.push({href: Astro.url.pathname, title: frontmatter.title});
---
<Default {frontmatter}
         {headings}
         contribute={true}
         {openGraphImage}
         {searchFilters}
         maxTocDepth={3}
         {...Astro.props}>
  <DocsNav {noSideNav} slot="nav" darkModeToggle={true} />
  <Sidebar slot="sideNav" {frontmatter} />
  <slot></slot>
</Default>
