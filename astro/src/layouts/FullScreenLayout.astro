---
import Head from 'src/components/Head.astro';

interface Props {
  frontmatter?: Record<string, any>;
  title?: string;
  description?: string;
}

const { frontmatter, title: titleProp, description: descProp } = Astro.props;

const title = frontmatter?.title ?? titleProp ?? '';
const description = frontmatter?.description ?? descProp ?? '';
---
<!doctype html>
<html lang="en">
  <Head {title} {description} />
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background-color: #ffffff;
  }

  main {
    margin: 0 !important;
    padding: 0 !important;
    width: 100vw;
    height: 100vh;
    max-width: 100vw !important;
  }
</style>
