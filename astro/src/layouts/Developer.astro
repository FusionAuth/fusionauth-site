---
import '../css/style.css';
import Default from './Default.astro';
import Head from '/src/components/Head.astro';
import DocsNav from '/src/components/nav/DocsNav.astro';
import Sidebar from '/src/components/Sidebar.astro';
import { getCollection } from 'astro:content';

const docsCollection = await getCollection('docs');
const basePath = '/docs'; 

const frontmatter = {
  "title": "FusionAuth Docs",
  "description": "A page in the FusionAuth Docs",
  "sideNavSimple": true,
  "section": "",
  "disableTOC": true,
}

const { title, description } = Astro.props;
---
<Default {frontmatter}
         copyMarkdown=true
         contribute={false}
         maxTocDepth={3}
         {...Astro.props}>
  <DocsNav noSideNav=true slot="nav" darkModeToggle={true} />
  <Sidebar slot="sideNav" {frontmatter} collection={docsCollection} {basePath} />
  <slot></slot>
</Default>
