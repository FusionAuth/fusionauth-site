---
import 'src/css/style.css';
import Head from 'src/components/Head.astro';
import Navigation from 'src/components/Navigation.astro';
import GitHubEdit from 'src/components/GitHubEdit.astro';
import DocSearch from 'src/components/search/DocSearch.astro';
import TOC from 'src/components/TOC.astro';
import { specialCaps } from 'src/tools/string';
import { Marked } from 'marked';
import Kapa from 'src/components/Kapa.astro';
import { Icon } from 'astro-iconset/components';
import CodeCopyButton from 'src/components/CodeCopyButton.astro';

interface Props {
  author?: string;
  date?: string;
  description?: string;
  disableTOC?: boolean;
  frontmatter?: Record<string, any>,
  headings?: any[];
  htmlTitle?: string;
  icon?: string;
  image?: string;
  openGraphImage?: string;
  section?: string;
  sections?: any[];
  sideMenu?: any[];
  title?: string;
  contribute?: boolean;
  breadcrumbs?: any[];
  maxTocDepth?: number;
  noBreadcrumb: boolean;
  isIndexPage?: boolean;
  hideBgImage?: boolean;
}

let {
  author,
  date,
  description = "Looks like the developers forgot to include a description for this page. Sorry about that.",
  disableTOC,
  frontmatter,
  headings = [],
  htmlTitle = "",
  icon,
  darkIcon,
  image,
  openGraphImage,
  section,
  sections = [],
  sideMenu = [],
  title = "",
  contribute = true,
  breadcrumbs = [],
  maxTocDepth,
  isIndexPage = false,
  hideBgImage = false,
}: Props = Astro.props;

author = frontmatter?.author ?? author;
date = frontmatter?.date ?? date;
description = frontmatter?.description ?? description;
icon = frontmatter?.icon ?? icon;
darkIcon = frontmatter?.darkIcon ?? darkIcon;
image = frontmatter?.image ?? image;
section = frontmatter?.section ?? section;
title = frontmatter?.title ?? title;
htmlTitle = frontmatter?.htmlTitle ?? title;
disableTOC = frontmatter?.disableTOC ?? disableTOC;
hideBgImage = frontmatter?.hideBgImage ?? frontmatter?.hidebgImage ?? hideBgImage;

const articleStyles = [
  // mobile overlay positioning
  "col-start-1 row-start-1 lg:col-auto lg:row-auto",
  // base
  "pb-24 prose prose-slate dark:prose-invert max-w-none min-w-0 w-full",
  // a
  "prose-a:no-underline prose-a:border-b-1 dark:prose-a:text-indigo-400 dark:prose-a:border-b-indigo-400 prose-a:border-b-indigo-700 prose-a:text-indigo-700 dark:prose-a:hover:text-orange-200 dark:prose-a:hover:border-b-orange-200 prose-a:hover:text-orange-800 prose-a:hover:border-b-orange-800",
  // code
  "prose-code:font-normal dark:prose-code:bg-slate-700/80 prose-code:bg-slate-200/80 prose-code:rounded-sm prose-code:break-words prose-code:px-0.5 prose-code:py-0.4",
  // headings
  "dark:prose-headings:text-slate-200 prose-headings:scroll-mt-24 prose-headings:text-slate-800 prose-headings:mb-4",
  // h2
  "prose-h2:mt-8",
  // li
  "prose-li:text-sm",
  // p
  "prose-p:text-sm prose-p:font-normal prose-p:leading-6 dark:prose-p:text-slate-300 prose-p:text-slate-800",
  // span
  "prose-span:text-slate-800 dark:prose-span:text-slate-300",
  // table
  "prose-table:block prose-table:rounded prose-table:overflow-x-scroll",
  // td
  "prose-td:border prose-td-border-collapse prose-td:border-opacity-75 prose-td:border-slate-400 dark:prose-td:border-slate-700 prose-td:px-4 prose-td:text-sm prose-td:font-normal prose-td:leading-5",
  // th
  "prose-th:border prose-th-border-collapse prose-th:border-opacity-75 prose-th:border-slate-400 dark:prose-th:border-slate-700 prose-th:px-4 prose-th:py-4 prose-th:text-base prose-th:font-semi-bold prose-th:leading-5",
  // tr
  "even:prose-tr:bg-slate-100 dark:even:prose-tr:bg-slate-800/50",
];

const mainStyles = [
  "mx-auto max-w-8xl px-4 pt-8",
  "grid grid-cols-1 lg:flex 2xl:container"
];

const sideNavStyles = [
  "col-start-1 row-start-1 lg:col-auto lg:row-auto",
  "hidden dark:bg-slate-900 bg-white sticky top-11 h-[calc(100vh-44px)] w-64 -ml-4 -mt-8 z-40 shadow-2xl lg:shadow-none",
  "lg:block lg:bg-opacity-0 lg:w-full lg:max-w-[270px] lg:ml-0 lg:mt-0 lg:px-0 lg:pt-0 lg:mr-6 lg:py-0 lg:top-[calc(6rem+1px)] lg:self-start overflow-y-auto lg:max-h-[calc(100vh-100px)] lg:h-auto"
];

const tocStyles = [
  "bottom-0 hidden overflow-hidden pb-10 pt-0 xl:block w-full max-w-[240px] ml-6 sticky top-24 self-start lg:max-h-[calc(100vh-100px)] z-10"
];

// used for copying markdown only
const path = Astro.url.pathname;
const fullMarkdownPath = path.replace(/.html$/,'.mdx');

const remark = new Marked();
const markdownifiedTitle = remark.parseInline(htmlTitle);
// remove simple markdown from string -- note that this is a hack that won't work for complex cases
const cleanedHtmlTitle = htmlTitle
  .replace(/[#*`_~]/g, '')
  .replace(/\[(.*?)\]\(.*?\)/g, '$1')
  .trim();
---

<!DOCTYPE html>
<html class="antialiased min-h-full" lang="en">
<Head title={`${cleanedHtmlTitle} | FusionAuth Docs`} description={description} canonicalUrl={frontmatter.canonicalUrl} {isIndexPage} {openGraphImage} />
<body class:list={[
  "font-sans antialiased bg-white min-h-full text-slate-700 dark:bg-slate-900 dark:text-slate-200",
  !hideBgImage && "bg-articles bg-right-top bg-no-repeat dark:bg-articles-dark"
]}>  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      // check for mermaid diagrams on page
      const blocks = document.querySelectorAll("pre code.language-mermaid");
      if (blocks.length === 0) return; // If no diagrams, stop here. Don't load Mermaid!
 
      // import Mermaid only when needed
      const { default: mermaid } = await import("mermaid");
 
      mermaid.initialize({ startOnLoad: false, theme: 'default' });
 
      blocks.forEach((block) => {
        const parent = block.parentElement;
        const mermaidDiv = document.createElement("div");
        mermaidDiv.className = "mermaid";
        mermaidDiv.textContent = block.textContent;
        parent.replaceWith(mermaidDiv);
      });
 
      await mermaid.run({
        querySelector: '.mermaid',
      });
    });
  </script>
  <slot name="nav"/>
  <main class:list={mainStyles}>
  <div id="side-nav" class:list={sideNavStyles}>
    <script is:inline>
      // restore the scroll position when a new page loads
      document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.getElementById('side-nav');
        if (sidebar) {
          const savedPos = sessionStorage.getItem('sidebarScrollPos');
          if (savedPos !== null) {
            sidebar.scrollTop = parseInt(savedPos, 10);
          }
        }
      });

      // save the scroll position in session storage right before leaving the current page
      window.addEventListener('beforeunload', () => {
        const sidebar = document.getElementById('side-nav');
        if (sidebar) {
          sessionStorage.setItem('sidebarScrollPos', sidebar.scrollTop.toString());
        }
      });
    </script>
    <div class="relative">
        <div class="bg-white hidden pb-1 pr-2 pt-0 sticky mt-0 top-0 self-start z-10 dark:bg-slate-900 lg:block">
          <DocSearch />
        </div>

      { Astro.slots.has('sideNav') &&
          <slot name="sideNav"></slot>
      }

      { !Astro.slots.has('sideNav') && <>

        <Navigation items={sideMenu}/>

        { contribute && <GitHubEdit {...Astro.props} /> }

      </>}

      </div>
    </div>

    <article class:list={articleStyles}>
      <div class="flex items-start">
        <div class="flex-grow">
          {breadcrumbs.length > 0 && <div class="flex flex-row not-prose hidden lg:block items-center pb-6">
            { breadcrumbs.map((crumb, i) => <>
              <a href={crumb.href} class="font-medium text-slate-500 mb-4 mt-0 text-sm hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:underline capitalize">{ specialCaps(crumb.title) }</a>
              { i !== breadcrumbs.length - 1 && <span class="mx-2 text-slate-500">/</span> }
            </>) }
          </div> }

          <h1 class:list={["text-3xl", image ? "mt-16" : "", author ? "mb-0" : ""]} set:html={markdownifiedTitle}></h1>

          {author &&
            <p class="m-0 text-sm">By {author} {date && <span>- {new Date(date).toDateString()}</span>}</p>
          }
        </div>
        {icon &&
          <img src={icon} alt={title} class="ml-8 mr-4 my-0 w-20 dark:hidden"/>
        }
        {darkIcon &&
          <img src={darkIcon} alt={title} class="ml-8 mr-4 my-0 w-20 hidden dark:block" />
        }
      </div>
      <section>
        <slot/>
      </section>

    </article>

    {!disableTOC &&
      <aside class:list={tocStyles}>
        <h3 class="font-semibold text-sm">On this page</h3>
        <nav>
          <TOC maxDepth={maxTocDepth}/>
        </nav>
      </aside>
    }
  </main>
  <Kapa />
  <CodeCopyButton />
</body>
</html>