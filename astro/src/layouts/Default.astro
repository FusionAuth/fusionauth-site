---
import 'src/css/style.css';
import Head from 'src/components/Head.astro';
import Navigation from 'src/components/Navigation.astro';
import GitHubEdit from 'src/components/GitHubEdit.astro';
import DocSearch from 'src/components/search/DocSearch.astro';
import TOC from 'src/components/TOC.astro';
import { specialCaps } from 'src/tools/string';
import { Marked } from 'marked';
import Kapa from 'src/components/Kapa.astro';
import CodeCopyButton from 'src/components/CodeCopyButton.astro';

interface Props {
  author?: string;
  date?: string;
  description?: string;
  disableTOC?: boolean;
  frontmatter?: Record<string, any>;
  headings?: any[];
  htmlTitle?: string;
  icon?: string;
  image?: string;
  openGraphImage?: string;
  section?: string;
  sections?: any[];
  sideMenu?: any[];
  title?: string;
  contribute?: boolean;
  breadcrumbs?: any[];
  maxTocDepth?: number;
  noBreadcrumb: boolean;
  isIndexPage?: boolean;
  hideBgImage?: boolean;
}

let {
  author,
  date,
  description = "Looks like the developers forgot to include a description for this page. Sorry about that.",
  disableTOC,
  frontmatter,
  headings = [],
  htmlTitle = "",
  icon,
  darkIcon,
  image,
  openGraphImage,
  section,
  sections = [],
  sideMenu = [],
  title = "",
  contribute = true,
  breadcrumbs = [],
  maxTocDepth,
  isIndexPage = false,
  hideBgImage = false,
} = Astro.props;

author = frontmatter?.author ?? author;
date = frontmatter?.date ?? date;
description = frontmatter?.description ?? description;
icon = frontmatter?.icon ?? icon;
darkIcon = frontmatter?.darkIcon ?? darkIcon;
image = frontmatter?.image ?? image;
title = frontmatter?.title ?? title;
htmlTitle = frontmatter?.htmlTitle ?? title;
disableTOC = frontmatter?.disableTOC ?? disableTOC;
hideBgImage = frontmatter?.hideBgImage ?? frontmatter?.hidebgImage ?? hideBgImage;

const mainStyles = "mx-auto max-w-8xl px-4 pt-8 grid grid-cols-1 lg:flex 2xl:container";
const sideNavStyles = "col-start-1 row-start-1 lg:col-auto lg:row-auto order-2 lg:order-1 hidden dark:bg-slate-900 bg-white sticky top-11 h-[calc(100vh-44px)] w-64 -ml-4 -mt-8 z-40 shadow-2xl lg:shadow-none lg:block lg:bg-opacity-0 lg:w-full lg:max-w-[270px] lg:ml-0 lg:mt-0 lg:px-0 lg:pt-0 lg:mr-6 lg:py-0 lg:top-[calc(6rem+1px)] lg:self-start overflow-y-auto lg:max-h-[calc(100vh-100px)] lg:h-auto";
const tocStyles = "order-3 lg:order-3 bottom-0 hidden overflow-hidden pb-10 pt-0 xl:block w-full max-w-[240px] ml-6 sticky top-24 self-start lg:max-h-[calc(100vh-100px)] z-10";

const isProd = import.meta.env.PROD as boolean;
const mdPath = isProd ? "LLM_MD_PATH_PLACEHOLDER" : Astro.url.pathname + "?format=md";

const remark = new Marked();
const markdownifiedTitle = remark.parseInline(htmlTitle);
const cleanedHtmlTitle = htmlTitle.replace(/[#*`_~]/g, '').replace(/\[(.*?)\]\(.*?\)/g, '$1').trim();
---

<!DOCTYPE html>
<html class="antialiased min-h-full" lang="en">
<Head title={`${cleanedHtmlTitle} | FusionAuth Docs`} description={description} canonicalUrl={frontmatter?.canonicalUrl} {isIndexPage} {openGraphImage} />
<body class:list={[
  "font-sans antialiased bg-white min-h-full text-slate-700 dark:bg-slate-900 dark:text-slate-200",
  !hideBgImage && "bg-articles bg-right-top bg-no-repeat dark:bg-articles-dark"
]}>  
  
  <script>
    // scroll to the current page in the left sidebar
    const sidebar = document.getElementById('side-nav');
    if (sidebar) {
      const savedPos = sessionStorage.getItem('sidebarScrollPos');
      if (savedPos !== null) sidebar.scrollTop = parseInt(savedPos, 10);
      window.addEventListener('beforeunload', () => {
        sessionStorage.setItem('sidebarScrollPos', sidebar.scrollTop.toString());
      });
    }

    // mermaid Initialization (Deferred natively by Astro)
    const blocks = document.querySelectorAll("pre code.language-mermaid");
    if (blocks.length > 0) {
      import("mermaid").then(({ default: mermaid }) => {
        mermaid.initialize({ startOnLoad: false, theme: 'default' });
        blocks.forEach((block) => {
          const mermaidDiv = document.createElement("div");
          mermaidDiv.className = "mermaid";
          mermaidDiv.textContent = block.textContent || "";
          if (block.parentElement) block.parentElement.replaceWith(mermaidDiv);
        });
        mermaid.run({ querySelector: '.mermaid' });
      });
    }

    // copy Button Logic
    const copyBtn = document.getElementById("copy-md-btn");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        try {
          const url = copyBtn.getAttribute("data-url");
          if (!url) return;
          const res = await fetch(url);
          if (!res.ok) throw new Error("Failed to fetch markdown");
          const text = await res.text();
          await navigator.clipboard.writeText(text);
          
          const originalHtml = copyBtn.innerHTML;
          copyBtn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="hidden sm:inline text-emerald-600 dark:text-emerald-400 font-medium">Copied!</span>
          `;
          setTimeout(() => copyBtn.innerHTML = originalHtml, 2000);
        } catch (err) {
          console.error("Copy failed", err);
        }
      });
    }
  </script>
  
  <slot name="nav"/>
  
  <main class={mainStyles}>
    
    <article class="fusion-article">
      <div class="sr-only">
        🤖 For AI agents: The complete documentation index is available at <a href="/docs/llms.txt">/docs/llms.txt</a>. 
        A markdown version of this page is available at <a href={mdPath}>{mdPath}</a>.
      </div>
      
      <div class="flex items-start justify-between w-full">
        <div class="flex-grow">
          {breadcrumbs.length > 0 && 
            <div class="flex flex-row not-prose hidden lg:block items-center pb-6">
              {breadcrumbs.map((crumb, i) => (
                <>
                  <a href={crumb.href} class="font-medium text-slate-500 mb-4 mt-0 text-sm hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:underline capitalize">{specialCaps(crumb.title)}</a>
                  {i !== breadcrumbs.length - 1 && <span class="mx-2 text-slate-500">/</span>}
                </>
              ))}
            </div>
          }

          <h1 class:list={["text-3xl", image ? "mt-16" : "", author ? "mb-0" : ""]} set:html={markdownifiedTitle}></h1>

          {author && <p class="m-0 text-sm">By {author} {date && <span>- {new Date(date).toDateString()}</span>}</p>}
        </div>
        
        <div class="flex flex-col items-end shrink-0 ml-4 sm:ml-8 mr-0 sm:mr-4 gap-4 not-prose">
          <div class="flex items-center gap-2">
            {contribute && <GitHubEdit {...Astro.props} />}
            
            <a href={mdPath} target="_blank" rel="noopener noreferrer" title="View Markdown" class="text-xs text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-300 flex items-center gap-1.5 border border-slate-200 dark:border-slate-700 rounded px-2.5 py-1.5 transition-colors bg-white dark:bg-slate-900 shadow-sm hover:shadow">
              <svg viewBox="0 0 16 16" fill="none" class="w-3.5 h-3.5"><path d="M14.85 3H1.15C.52 3 0 3.52 0 4.15v7.7c0 .63.52 1.15 1.15 1.15h13.7c.63 0 1.15-.52 1.15-1.15v-7.7C16 3.52 15.48 3 14.85 3zM9 11H7V5.5L4.5 8 2 5.5V11H1V4h1l2.5 2.5L7 4h2v7zm4.5 0L11 8h1.5V4h1v4H15l-1.5 3z" fill="currentColor"/></svg>
              <span class="font-medium hidden sm:inline">MD</span>
            </a>
            
            <button id="copy-md-btn" data-url={mdPath} title="Copy Markdown" class="text-xs text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-300 flex items-center gap-1.5 border border-slate-200 dark:border-slate-700 rounded px-2.5 py-1.5 transition-colors bg-white dark:bg-slate-900 shadow-sm hover:shadow cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              <span class="font-medium hidden sm:inline">Copy</span>
            </button>
          </div>

          {icon && <img src={icon} alt={title} class="w-20 my-0 dark:hidden"/>}
          {darkIcon && <img src={darkIcon} alt={title} class="w-20 my-0 hidden dark:block" />}
        </div>
      </div>

      <section>
        <slot/>
      </section>

    </article>

    <div id="side-nav" class={sideNavStyles}>
      <div class="relative">
        <div class="bg-white hidden pb-1 pr-2 pt-0 sticky mt-0 top-0 self-start z-10 dark:bg-slate-900 lg:block">
          <DocSearch />
        </div>

        {Astro.slots.has('sideNav') ? <slot name="sideNav"></slot> : <Navigation items={sideMenu}/>}
      </div>
    </div>

    {!disableTOC &&
      <aside class={tocStyles}>
        <h3 class="font-semibold text-sm">On this page</h3>
        <nav>
          <TOC maxDepth={maxTocDepth}/>
        </nav>
      </aside>
    }
  </main>
  
  <Kapa />
  <CodeCopyButton />
</body>
</html>