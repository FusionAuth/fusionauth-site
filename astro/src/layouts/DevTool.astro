---
import { getCollection } from "astro:content";
import Default from "./Default.astro";
import DevToolsNav from "../components/nav/DevToolsNav.astro";
import PostHog from "src/components/PostHog.astro";

const tools = await getCollection("dev-tools");
const sections = [];
for (const tool of tools) {
  if (tool.id.indexOf("index.md") !== -1) {
    continue;
  }

  sections.push({
    title: tool.data.title,
    path: `/dev-tools/${tool.id}`,
    icon: tool.data.faIcon,
    color: tool.data.color,
  });
}
---

<Default sections={sections} sideMenu={[]} {...Astro.props}>
  <PostHog />
  <DevToolsNav slot="nav" />
  <slot />

  <script>
    const testPromo = document.querySelector(".test-promo");
    const anchors = testPromo.querySelectorAll('a')
    for (let i=0; i<anchors.length; i++) {
      anchors[i].addEventListener('click', () => {
        window.posthog.capture("clinked_link");
      })
    }
   
  </script>
</Default>


