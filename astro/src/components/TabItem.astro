---
import { Marked } from "marked";

interface Props {
  label: string;
}

const { label } = Astro.props;

const id = `tab-${Math.random().toString(36).substring(2, 9)}`;

const remark = new Marked();
const markdownifiedLabel = remark.parseInline(label);
---

<input 
  type="radio" 
  name="%%TAB_GROUP%%" 
  id={id} 
  class="tab-input sr-only" 
/>

<label 
  for={id} 
  class="tab-label order-1 px-4 py-1.5 my-1 ml-1 text-sm font-medium rounded-md cursor-pointer transition-all whitespace-nowrap text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
>
  <span set:html={markdownifiedLabel} />
</label>

<div class="tab-panel order-2 w-full hidden p-4 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
  <slot />
</div>

<style>
  /* Style ONLY the immediate label after the checked input */
  .tab-input:checked + .tab-label {
    font-weight: 700;
    background-color: #ffffff;
    color: #2563eb; /* text-blue-600 */
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05); /* shadow-sm */
  }

  :global(.dark) .tab-input:checked + .tab-label {
    background-color: #374151; /* bg-gray-700 */
    color: #60a5fa; /* text-blue-400 */
  }

  /* Show ONLY the panel that directly follows the active label */
  .tab-input:checked + .tab-label + .tab-panel {
    display: block;
  }
</style>