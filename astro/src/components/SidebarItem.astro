---
import { Marked } from "marked";

const { node } = Astro.props;

const childNodes = node.sortedChildren || [];
const hasChildren = childNodes.length > 0;

const isCurrent = node.isCurrentPage;
const isAncestor = node.isActive && !isCurrent;

let stateClasses = "sidebar-state-default";
if (isCurrent) {
  stateClasses = "sidebar-state-current";
} else if (isAncestor) {
  stateClasses = "sidebar-state-ancestor";
}

const remark = new Marked();
const markdownifiedTitle = remark.parseInline(node.title);
---

{hasChildren ? (
  <details class="group/folder" open={node.isOpen}>
    <summary class="sidebar-summary">
      {node.href ? (
        <a 
          href={`${node.href}/`}
          class={`sidebar-link ${stateClasses}`}
          aria-current={isCurrent ? "page" : undefined}
          set:html={markdownifiedTitle}
        >
        </a>
      ) : (
        <span class={`sidebar-link cursor-default ${stateClasses}`} set:html={markdownifiedTitle}></span>
      )}
      
      <div 
        aria-hidden="true" 
        class={`p-1.5 rounded-md transition-colors hover:group-open/folder:bg-gray-100 dark:hover:group-open/folder:bg-gray-800 hover:group-open/folder:text-gray-900 dark:hover:group-open/folder:text-gray-100 ${isCurrent ? 'text-indigo-500' : 'text-gray-400'}`}
      >
        <svg 
          class="w-3.5 h-3.5 transition-transform duration-200 shrink-0 chevron-icon" 
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </summary>
    
    <div class="pl-3 mt-1 ml-2 border-l border-gray-200 dark:border-gray-800 flex flex-col gap-1">
      {childNodes.map(child => <Astro.self node={child} />)}
    </div>
  </details>
) : (
  <a 
    href={node.href} 
    aria-current={isCurrent ? "page" : undefined}
    class={`sidebar-child-link ${stateClasses}`}
    set:html={markdownifiedTitle}
  >
  </a>
)}