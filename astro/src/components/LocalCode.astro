---
// Local snippet loader for code stored in src/generated-code-snippets, src/code-example-repositories, or src/code-example-internal.
// Auto-detects: paths containing ".snippet." read from generated snippets; all others check code-example-repositories first, then code-example-internal.

import { CodeLanguage } from 'astro';
import { Code } from 'astro:components';
import fs from 'fs';
import path from 'path';

export interface Props {
  /**
   * File path relative to src/code-example-repositories (source), src/code-example-internal (local-only), or src/generated-code-snippets (snippet).
   * Snippet paths contain ".snippet." in the filename, e.g. "webauthn/base64url-to-buffer.snippet.base64url-to-buffer.js"
   * Source paths point directly to repo files, e.g. "fusionauth-quickstart-react-main/react-frontend-steps/1-customized/src/main.tsx"
   */
  src: string;

  /**
   * The language of your code.
   * Bluehawk supports all languages listed here: https://github.com/shikijs/shiki/blob/main/docs/languages.md#all-languages
   *
   * @default "plaintext"
   */
  lang: CodeLanguage;

  /**
   * The title of the code section, shown as a piece of text above the block.
   */
  title?: string;
}

const { src, lang = 'plaintext', title, ...rest } = Astro.props;

const externalPath = path.join(process.cwd(), 'src', 'code-example-repositories', src);
const internalPath = path.join(process.cwd(), 'src', 'code-example-internal', src);
const snippetPath = src.includes('.snippet.')
  ? path.join(process.cwd(), 'src', 'generated-code-snippets', src)
  : fs.existsSync(externalPath) ? externalPath : internalPath;
let snippetCode = '';

try {
  snippetCode = fs.readFileSync(snippetPath, 'utf-8').trim();
}
catch (err) {
  throw new Error(`Failed to read local code file at [${snippetPath}]: ${(err as Error).message}`);
}

---
{(title === '' || title === undefined) ? null : (<p data-title={title}><em>{title}</em></p>)}
<Code code={snippetCode} lang={lang} {...rest}/>
