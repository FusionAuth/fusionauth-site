---
import { Icon } from "astro-iconset/components";

interface Props {
    icon: string;
    color?: 'blue' | 'green' | 'red' | 'gray' | 'purple';
}

const {icon, color = 'blue'} = Astro.props;

---
<span class:list={["btn-icon size-7 border rounded-sm bg-(--color) text-(--text-color) border-(--border-color) inline-flex items-center justify-center align-[-0.25em]", 'btn-icon-' + color]}>
    <Icon name={`fa7-solid:${icon}`} class="block h-4" size="16" />
</span>

<style>
  .btn-icon {
    --color: #fff;
    --border-color: var(--color);
    --text-color: white;

    &.btn-icon-blue {
      --color: #3998db;
    }

    &.btn-icon-green {
      --color: #0bb796;
    }

    &.btn-icon-red {
      --color: #ee3e54;
    }

    &.btn-icon-purple {
      --color: #34485e;
    }

    &.btn-icon-gray {
      --border-color: #bfbfbf;
      --color: #f7f7f7;
      --text-color: #262626;
    }
  }
</style>
