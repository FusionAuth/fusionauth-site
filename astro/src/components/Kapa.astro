---
import { Icon } from "astro-iconset/components";
import PurpleLogo from 'src/img/fa_logo_purple_orange.svg';
import WhiteLogo from 'src/img/fa_logo_white_orange.svg';

const {
  enableKapa = true,
} = Astro.props;

if (!enableKapa) return '';
---

<div class="fixed right-5 bottom-5 z-100">
    <button id="kapa-button" class="relative flex flex-col items-center justify-center h-20 w-18 cursor-pointer rounded-lg border border-slate-200 dark:bg-slate-900 dark:border-slate-800 bg-white dark:hover:bg-slate-800 dark:hover:border-indigo-500 group hover:bg-slate-100 hover:border-indigo-500 overflow-hidden shadow-lg">
        <PurpleLogo viewBox="0 0 200 200" class="size-9 group-hover:scale-110 transition-transform duration-500 dark:hidden" />
        <WhiteLogo viewBox="0 0 200 200" class="size-9 group-hover:scale-110 transition-transform duration-500 hidden dark:block" />

        <span class="text-lg">Ask AI</span>

        <span id="kapa-spinner" class="absolute inset-0 bg-black/10 dark:bg-black/50 transition-opacity duration-300 hidden items-center justify-center">
            <Icon name="fa7-solid:spinner" class="h-8 animate-spin [animation-duration:2s]" size={32} />
        </span>
    </button>
</div>

<script is:inline>
  (function() {
    const btn = document.getElementById('kapa-button');
    const spinner = document.getElementById('kapa-spinner');
    const scriptSrc = "https://widget.kapa.ai/kapa-widget.bundle.js";

    if (!btn) return;

    async function loadKapa() {
      return new Promise((resolve) => {
        if (window.Kapa) {
          resolve();
          return;
        }

        const script = document.createElement("script");
        script.src = scriptSrc;
        script.async = true;

        const attrs = {
          "data-website-id": "26ad3b7e-7d94-491c-ab54-95712d1fafee",
          "data-project-name": "FusionAuth",
          "data-project-color": "#0F172A",
          "data-project-logo": "https://uploads-ssl.webflow.com/617b1b1f42c1da41aeae3413/663bee0e6eec6b85377a3939_fa-square-icon-144.png",
          "data-render-on-load": "false",
          'data-user-analytics-cookie-enabled': "false",
          'data-button-animation-enabled': "false",
          'data-mcp-server-url': "https://ai.fusionauth.io/mcp/docs",
          'data-mcp-button-hidden': "false",
          'data-launcher-button-hidden': "true",
        };

        Object.entries(attrs).forEach(([k, v]) => script.setAttribute(k, v));

        script.onload = () => {
          window.Kapa.render({
            onRender: () => resolve()
          });
        };

        document.head.appendChild(script);
      });
    }

    btn.addEventListener('click', async () => {
      spinner.style.display = 'flex';

      await loadKapa();

      if (window.Kapa) {
        window.Kapa("open");
      }

      spinner.style.display = 'none';
    });
  })();
</script>