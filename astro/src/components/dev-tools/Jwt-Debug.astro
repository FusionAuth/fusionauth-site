---
import { Icon } from "astro-iconset/components";
import Textarea from "src/components/Textarea.astro";
---

<div id="notificationPanel" class="hidden px-4 py-3 rounded relative mb-4 mt-5 transition-colors duration-200">
  <Icon name="fa7-solid:check" class="inline h-4 mr-2 icon icon-success hidden" />
  <Icon name="fa7-solid:x" class="inline h-4 mr-2 icon icon-error hidden" />
  <p class="notificationMessage inline font-medium"></p>
</div>

<form class="gap-y-6 grid md:grid-cols-2 gap-5 mt-4 mb-8">
  <div class="row-span-3 flex flex-col h-full">
    <Textarea 
      id="encoded-textarea" 
      name="encoded-textarea" 
      label="JSON Web Token (JWT)" 
      required={false} 
      instructions="Paste your JWT or examine the default." 
    />
  </div>
  
  <div class="flex flex-col">
    <Textarea 
      id="header-textarea" 
      name="header-textarea" 
      label="Header" 
      required={false} 
      instructions="Header derived from the first string in the JWT (modifying changes the JWT)." 
    />
  </div>
  
  <div class="flex flex-col">
    <Textarea 
      id="payload-textarea" 
      name="payload-textarea" 
      label="Payload" 
      required={false} 
      instructions="Payload derived from the second string in the JWT (modifying changes the JWT)." 
    />
  </div>
  
  <div class="flex flex-col">
    <Textarea 
      id="secret-text" 
      name="secret-text" 
      label="Signature validation" 
      required={false} 
      instructions="Enter your Secret, PEM, or JWK depending on the signing algorithm." 
    />
  </div>
</form>

<div class="disclaimer border border-yellow-400 bg-yellow-50 dark:border-yellow-400 dark:bg-yellow-800 rounded px-4 py-3 mb-10 flex items-start gap-3">
  <Icon name="fa7-solid:circle-exclamation" class="inline shrink-0 text-xl text-yellow-600 mt-0.5" />
  <p class="text-sm italic m-0">FusionAuth respects and protects your data, which never leaves this page. But please don't paste real production tokens here. Treat production JWTs like passwords! Whenever possible, use local development tokens for debugging.</p>
</div>

<script>
  import * as jose from "jose";
  import { verify } from "jsonwebtoken-esm";

  const defaultToken = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpYXQiOjE0ODUxMzczODQsImlzcyI6ImFjbWUuY29tIiwic3ViIjoiMjlhYzBjMTgtMGI0YS00MmNmLTgyZmMtMDNkNTcwMzE4YTFkIiwiYXBwbGljYXRpb25JZCI6Ijc5MTAzNzM0LTk3YWItNGQxYS1hZjM3LWUwMDZkMDVkMjk1MiIsInJvbGVzIjpbXX0.uTekOEtlWN8C4wGNeL2C-HtI10OM8VKnDsW-WG4TSi0";
  const defaultSecret = "dqTl/KjAFRqmdpz7ZlFspWgo8Fkbp1Lzd8sd8ea66XM=";

  // DOM Elements (Checks if the component wraps the ID or if it's on the input itself)
  const getField = (id) => {
    const el = document.getElementById(id);
    if (!el) return null;
    return el.tagName === 'TEXTAREA' || el.tagName === 'INPUT' ? el : el.querySelector('textarea, input');
  };

  const tokenInput = getField("encoded-textarea");
  const headerInput = getField("header-textarea");
  const payloadInput = getField("payload-textarea");
  const secretInput = getField("secret-text");
  
  const notificationPanel = document.getElementById("notificationPanel");
  const notificationMessage = notificationPanel?.querySelector(".notificationMessage");
  const iconSuccess = notificationPanel?.querySelector(".icon-success");
  const iconError = notificationPanel?.querySelector(".icon-error");

  function stringIsJSON(toCheck) {
    try {
      JSON.parse(toCheck);
      return true;
    } catch (e) {
      return false;
    }
  }

  function displayError(error) {
    if (!notificationPanel) return;
    notificationPanel.classList.remove("hidden", "bg-green-100", "border-green-400", "text-green-700");
    notificationPanel.classList.add("bg-red-100", "border", "border-red-400", "text-red-700", "dark:bg-red-900", "dark:text-red-300");
    if (iconSuccess) iconSuccess.classList.add("hidden");
    if (iconError) iconError.classList.remove("hidden");
    if (notificationMessage) notificationMessage.innerText = error;
  }

  function clearError() {
    if (!notificationPanel) return;
    notificationPanel.classList.remove("hidden", "bg-red-100", "border-red-400", "text-red-700", "dark:bg-red-900", "dark:text-red-300");
    notificationPanel.classList.add("bg-green-100", "border", "border-green-400", "text-green-700", "dark:bg-green-900", "dark:text-green-300");
    if (iconError) iconError.classList.add("hidden");
    if (iconSuccess) iconSuccess.classList.remove("hidden");
    if (notificationMessage) notificationMessage.innerText = "JWT and Signature are valid";
  }

  function decodeBase64Url(str) {
    let base64 = str.replace(/-/g, '+').replace(/_/g, '/');
    const pad = base64.length % 4;
    if (pad) base64 += '='.repeat(4 - pad);
    try {
        return decodeURIComponent(window.atob(base64).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
    } catch (e) {
        return window.atob(base64);
    }
  }

  function encodeBase64Url(str) {
    const base64 = window.btoa(unescape(encodeURIComponent(str)));
    return base64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
  }

  async function verifyJwt(jwt, secret = defaultSecret) {
    if (!jwt || jwt.split('.').length !== 3) return;
    try {
      clearError();
      if (stringIsJSON(secret)) {
        let JWKS;
        const jsonSecret = JSON.parse(secret);
        if (jsonSecret.keys) {
          JWKS = jose.createLocalJWKSet(jsonSecret);
        } else {
          JWKS = jose.createLocalJWKSet({ keys: [jsonSecret] });
        }
        await jose.jwtVerify(jwt, JWKS);
      } else {
        verify(jwt, secret, {
          algorithms: ["HS256", "HS512", "HS384", "RS256", "RS384", "RS512", "ES256", "ES384", "ES512", "PS256", "PS384", "PS512"],
        });
      }
    } catch (e) {
      if (e.name === "TypeError") {
        displayError("The public key does not match the current token.");
      } else {
        displayError("Verification error: " + e.message);
      }
    }
  }

  function updateFromToken() {
    const token = tokenInput.value;
    const parts = token.split(".");
    let head = "", pay = "";

    if (parts.length > 0 && parts[0]) {
      try {
        head = JSON.stringify(JSON.parse(decodeBase64Url(parts[0])), null, 2);
      } catch(e) {
        head = "Invalid Header";
        displayError("Token header is invalid");
      }
    }
    if (parts.length > 1 && parts[1]) {
      try {
        pay = JSON.stringify(JSON.parse(decodeBase64Url(parts[1])), null, 2);
      } catch(e) {
        pay = "Invalid Payload";
        displayError("Token payload is invalid");
      }
    }

    headerInput.value = head;
    payloadInput.value = pay;

    if (parts.length === 3) {
      verifyJwt(token, secretInput.value);
    } else {
      displayError("JWT must have 3 parts (Header, Payload, Signature).");
    }
  }

  function updateFromParts() {
    let newHead, newPay;
    try {
      newHead = encodeBase64Url(JSON.stringify(JSON.parse(headerInput.value)));
    } catch(e) { return; } // Ignore invalid JSON while typing

    try {
      newPay = encodeBase64Url(JSON.stringify(JSON.parse(payloadInput.value)));
    } catch(e) { return; } 

    const parts = tokenInput.value.split(".");
    const sig = parts.length === 3 ? parts[2] : "";

    const newToken = `${newHead}.${newPay}.${sig}`;
    tokenInput.value = newToken;
    verifyJwt(newToken, secretInput.value);
  }

  // Bind Events on mount
  if (tokenInput && headerInput && payloadInput && secretInput) {
    // Set Defaults
    tokenInput.value = defaultToken;
    secretInput.value = defaultSecret;

    // Listeners
    tokenInput.addEventListener("input", updateFromToken);
    secretInput.addEventListener("input", () => verifyJwt(tokenInput.value, secretInput.value));
    headerInput.addEventListener("input", updateFromParts);
    payloadInput.addEventListener("input", updateFromParts);

    // Initial Trigger
    updateFromToken();
  }
</script>

<style>
  /* Ensure the textareas have a good minimum height for viewing JSON objects */
  :global(#encoded-textarea),
  :global(#encoded-textarea textarea) {
    min-height: 250px;
    height: 100%;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }
  
  :global(#header-textarea textarea), 
  :global(#payload-textarea textarea), 
  :global(#secret-text textarea) {
    min-height: 120px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }
</style>