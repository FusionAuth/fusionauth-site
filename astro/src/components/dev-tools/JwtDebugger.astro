---
import { Icon } from "astro-iconset/components";
---

<jwt-debugger>
  <div id="notificationPanel" class="success">
    <Icon name="fa7-solid:check" class="inline h-4 icon icon-success"/>
    <Icon name="fa7-solid:x" class="inline h-4 icon icon-error"/>
    <p class="notificationMessage inline">JWT and Signature are valid</p>
  </div>

  <div
      class="gap-y-6 grid md:grid-cols-2 md:grid-rows-[auto,auto,auto] gap-5 mt-4 mb-8 md:min-h-[300px]"
  >
    <div
        id="encoded-textarea"
        class="row-span-3 flex-1 border-0 rounded text-sm w-full focus:outline-none focus:ring-0"
    >
      <span class="label block font-medium mb-1">JSON Web Token (JWT) <span class="block mt-1 font-light text-xs italic">Paste your JWT or examine the default</span></span>
    </div>
    <div
        id="header-textarea"
        class="flex-1 h-[min-content] border-0 rounded text-sm w-full focus:outline-none focus:ring-0"
    >
    <span class="label block font-medium mb-1">Header
      <span class="block mt-1 font-light text-xs italic">Header derived from the first string in the JWT (modifying changes the JWT)</span>
    </span>
    </div>

    <div
        id="payload-textarea"
        class="flex-1 border-0 rounded text-sm focus:outline-none focus:ring-0"
    >
    <span class="label block font-medium mb-1">Payload
      <span class="block mt-1 font-light text-xs italic">Payload derived from the second string in the JWT (modifying changes the JWT)</span>
    </span>
    </div>
    <div
        id="secret-text"
        class="flex-1 border-0 rounded text-sm focus:outline-none focus:ring-0"
    >
      <span class="label block font-medium mb-1">Signature validation <span id="signatureHelp" class="block mt-1 font-light text-xs italic">Enter your Secret, PEM, or JWK depending on the signing algorithm.</span></span>
    </div>
  </div>

  <div class="disclaimer border border-yellow-400 bg-yellow-50 dark:border-yellow-400 dark:bg-yellow-800 rounded px-4 mb-10 flex items-center gap-2">
    <Icon name="fa7-solid:circle-exclamation" class="inline shrink-0 text-3xl text-yellow-600"/>
    <p class="text-xs italic">FusionAuth respects and protects your data, which never leaves this page. But please don't paste real production tokens here. Treat production JWTs like passwords!
      Whenever possible, use local development tokens for debugging.</p>
  </div>
</jwt-debugger>

<script>
  import { json } from "@codemirror/lang-json";
  import { MatchDecorator, ViewPlugin, Decoration, EditorView, ViewUpdate } from "@codemirror/view";
  import { basicSetup } from "codemirror";
  import { Transaction } from "@codemirror/state";
  import { verify } from "jsonwebtoken-esm";
  import { createLocalJWKSet, JWK, jwtVerify } from "jose";

  const defaultToken =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpYXQiOjE0ODUxMzczODQsImlzcyI6ImFjbWUuY29tIiwic3ViIjoiMjlhYzBjMTgtMGI0YS00MmNmLTgyZmMtMDNkNTcwMzE4YTFkIiwiYXBwbGljYXRpb25JZCI6Ijc5MTAzNzM0LTk3YWItNGQxYS1hZjM3LWUwMDZkMDVkMjk1MiIsInJvbGVzIjpbXX0.uTekOEtlWN8C4wGNeL2C-HtI10OM8VKnDsW-WG4TSi0";
  const defaultSecret =
    "dqTl/KjAFRqmdpz7ZlFspWgo8Fkbp1Lzd8sd8ea66XM=";

  const tokenDec = Decoration.mark({class: "headerDec"});
  const tokenDecorator = new MatchDecorator({
    regexp: /([^.]+)/g,
    decoration: () => tokenDec
  });
  const tokenColors = ViewPlugin.define(
    (view) => ({
      decorations: tokenDecorator.createDeco(view),
      update(u) {
        this.decorations = tokenDecorator.updateDeco(u, this.decorations);
      },
    }),
    {
      decorations: (v) => v.decorations,
    },
  );

  class JwtDebugger extends HTMLElement {
    private encodedEditor: EditorView;
    private headerEditor: EditorView;
    private payloadEditor: EditorView;
    private secretEditor: EditorView;
    private notificationPanel: HTMLDivElement;

    connectedCallback() {
      const encodedTextarea = this.querySelector('#encoded-textarea') as HTMLTextAreaElement;
      const headerTextarea = this.querySelector('#header-textarea') as HTMLTextAreaElement;
      const payloadTextarea = this.querySelector('#payload-textarea') as HTMLTextAreaElement;
      const secretTextarea = this.querySelector('#secret-text') as HTMLTextAreaElement;
      this.notificationPanel = this.querySelector('#notificationPanel') as HTMLDivElement;

      this.encodedEditor = new EditorView({
        parent: encodedTextarea,
        extensions: [
          tokenColors,
          EditorView.lineWrapping,
          EditorView.updateListener.of((e) => {
            if (this.shouldUpdate(e)) {
              const newValue = e.state.doc.toString();
              const {headers, payload} = this.decodeJwt(newValue);
              this.updateEditorValue(this.headerEditor, headers);
              this.updateEditorValue(this.payloadEditor, payload);
              this.verifyJwt();
            }
          })
        ],
        doc: defaultToken
      });

      const {headers, payload} = this.decodeJwt(defaultToken);

      this.headerEditor = new EditorView({
        parent: headerTextarea,
        extensions: [
          basicSetup,
          EditorView.lineWrapping,
          json(),
          EditorView.updateListener.of((e) => {
            if (this.shouldUpdate(e)) {
              const newValue = e.state.doc.toString();
              const currentToken = this.encodedEditor.state.doc.toString().split(".");
              try {
                const updatedHeader = btoa(newValue);
                this.updateEditorValue(this.encodedEditor, `${updatedHeader}.${currentToken[1] || ''}.${currentToken[2] || ''}`);
              } catch (e) {
                // Ignore encoding errors while typing
              }
            }
          })
        ],
        doc: headers
      });

      this.payloadEditor = new EditorView({
        parent: payloadTextarea,
        extensions: [
          basicSetup,
          EditorView.lineWrapping,
          json(),
          EditorView.updateListener.of((e) => {
            if (this.shouldUpdate(e)) {
              const newValue = e.state.doc.toString();
              const currentToken = this.encodedEditor.state.doc.toString().split(".");
              try {
                const updatedPayload = btoa(newValue);
                this.updateEditorValue(this.encodedEditor, `${currentToken[0] || ''}.${updatedPayload}.${currentToken[2] || ''}`);
              } catch (e) {
                // Ignore encoding errors while typing
              }
            }
          })
        ],
        doc: payload
      });

      this.secretEditor = new EditorView({
        parent: secretTextarea,
        extensions: [
          basicSetup,
          EditorView.lineWrapping,
          tokenColors,
          EditorView.updateListener.of((e) => {
            if (this.shouldUpdate(e)) {
              this.verifyJwt();
            }
          })
        ],
        doc: defaultSecret
      });
    }

    private shouldUpdate(e: ViewUpdate) {
      return e.docChanged && e.transactions.some(t => t.annotation(Transaction.userEvent));
    }

    private updateEditorValue(view: EditorView, newValue: string) {
      if (view.state.doc.toString() === newValue) return;
      view.dispatch({
        changes: {from: 0, to: view.state.doc.length, insert: newValue}
      });
    }

    decodeJwt(stringToDecode) {
      const s = stringToDecode.split(".");
      let headers, payload;
      try {
        headers = JSON.stringify(JSON.parse(atob(s[0])), null, 2);
      } catch (e) {
        headers = JSON.stringify({"error": "Token header is invalid"}, null, 2);
      }

      try {
        payload = JSON.stringify(JSON.parse(atob(s[1])), null, 2);
      } catch (e) {
        payload = JSON.stringify({"error": "Token payload is invalid"}, null, 2);
      }
      return {payload, headers};
    }

    stringIsJSON(toCheck: string) {
      try {
        window.JSON.parse(toCheck)
        return true;
      } catch (e) {
        return false;
      }
    }

    async verifyJwt() {
      try {
        const jwt = this.encodedEditor.state.doc.toString();
        const secret = this.secretEditor.state.doc.toString();

        if (this.stringIsJSON(secret)) {
          const jsonSecret = window.JSON.parse(secret);

          const JWKS = createLocalJWKSet(jsonSecret.keys ? jsonSecret : {
            keys: [jsonSecret]
          });
          await jwtVerify(jwt, JWKS);
        } else {
          verify(jwt, secret, {
            algorithms: ["HS256", "HS512", "HS384", "RS256", "RS384", "RS512", "ES256", "ES384", "ES512", "PS256", "PS384", "PS512"],
          });
        }
      } catch (e) {
        if (e instanceof TypeError) {
          this.updateError("The Public Key you entered is does not match the current token")
        } else {
          this.updateError("The Secret or Public Key gave the following error: " + e.message)
        }
        return;
      }
      this.updateError();
    }

    updateError(error?: string) {
      this.notificationPanel.classList.toggle('error', !!error);
      this.notificationPanel.classList.toggle('success', !error);
      this.notificationPanel.querySelector('.notificationMessage').textContent = error ?? 'JWT and Signature are valid';
    }
  }

  customElements.define('jwt-debugger', JwtDebugger);
</script>

<style is:global>
    @reference "tailwindcss";

    .fieldHelp {
        @apply block mt-1 font-light text-xs italic;
    }

    #encoded-textarea {
        @apply grid grid-rows-[min-content_minmax(0,1fr)];
    }
    #header-textarea .cm-editor {
        @apply md:max-h-[max-content];
    }

    #secret-text .cm-editor {
        max-height: 400px;
    }
    #payload-textarea .cm-editor {
        @apply md:max-h-[max-content];
    }
    .cm-editor {
        @apply flex-1 bg-white rounded-md border border-slate-400 p-2;
    }
    .cm-editor {
        max-height: 100%;
    }
    .cm-scroller {
        overflow: auto;
    }

    .dark .cm-editor {
        @apply bg-slate-900;
    }
    .dark .cm-focused .cm-cursor {
        border-left: 1px solid white !important;
    }
    .cm-editor .cm-activeLine {
        background: transparent;
    }
    .cm-editor .cm-gutters.cm-gutters-before {
        display: none;
    }
    .cm-gutters {
        min-height: initial !important;
    }
    .headerDec:first-of-type {
        @apply text-green-600;
    }
    .headerDec:first-of-type:hover {
        @apply bg-green-100;
    }
    .dark .headerDec:first-of-type:hover {
        @apply bg-green-900;
    }
    .headerDec:nth-of-type(2) {
        @apply text-indigo-600;
    }
    .headerDec:nth-of-type(2):hover {
        @apply bg-indigo-100;
    }
    .dark .headerDec:nth-of-type(2):hover {
        @apply bg-indigo-700;
    }
    .dark .headerDec:first-of-type {
        @apply text-green-300;
    }
    .dark .headerDec:nth-of-type(2) {
        @apply text-indigo-300;
    }
    .headerDec:nth-of-type(3) {
        @apply text-red-600;
    }
    .headerDec:nth-of-type(3):hover {
        @apply bg-red-100;
    }
    .dark .headerDec:nth-of-type(3) {
        @apply text-red-500;
    }
    .dark .headerDec:nth-of-type(3):hover {
        @apply bg-red-900;
    }

    .dark .ͼc {
        @apply text-blue-400;
    }
    .cm-line {
        @apply text-indigo-800;
    }
    .dark .cm-line {
        @apply text-indigo-100;
    }
    .ͼe {
        @apply text-red-700;
    }
    .ͼd {
        @apply text-green-700;
    }
    .dark .ͼe {
        @apply text-orange-300;
    }
    .dark .ͼd {
        @apply text-green-300;
    }

    #notificationPanel:empty {
        @apply hidden;
    }

    #notificationPanel {
        @apply px-4 py-3 rounded relative mb-0 mt-5;
    }

    #notificationPanel.success {
        @apply bg-green-100 border border-green-400 text-green-700;
    }

    .dark #notificationPanel.success {
        @apply bg-green-900 text-green-300;
    }

    .dark #notificationPanel.error {
        @apply bg-red-900 text-red-300;
    }

    .icon-error,
    .icon-success {
        @apply hidden;
    }

    #notificationPanel.error {
        @apply bg-red-100 border border-red-400 text-red-700;
    }

    .error .icon-error,
    .success .icon-success {
        @apply inline;
    }
</style>
