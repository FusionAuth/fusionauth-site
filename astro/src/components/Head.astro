---
import Font from 'astro/components/Font.astro';

interface Props {
  description?: string;
  enableBaseParent?: boolean;
  enableGTM?: boolean;
  title?: string;
  openGraphImage?: string;
  canonicalUrl?: string;
  isIndexPage?: boolean;
  applyTheme?: boolean;
}

const {
  description,
  enableBaseParent = false,
  enableGTM = true,
  title, openGraphImage,
  canonicalUrl,
  applyTheme = true,
  isIndexPage = false,
} = Astro.props;
const openGraphImageUrl = openGraphImage ? new URL(openGraphImage, Astro.url): new URL("/img/og/articles-developers-v1.png", Astro.url);
const normalizedUrl = Astro.url.toString().replace(/.html$/, '');
const isProd = import.meta.env.PROD as boolean;

let canonical = canonicalUrl;
if (!canonical) {
  canonical = Astro.url.href;
} else if (!canonical.startsWith('http')) {
  canonical = new URL(canonical, Astro.url).href;
}

if (canonical.endsWith('index.html')) {
  canonical = canonical.slice(0, canonical.indexOf('index.html'));
  if (!canonical.endsWith('/')) {
    canonical += '/';
  }
} else if (canonical.endsWith('.html')) {
  canonical = canonical.slice(0, canonical.indexOf('.html'));
}

// Pages built from index.mdx are served as a directory (with trailing slash);
// standalone .mdx files are served without one. Match whichever URL is served.
if (isIndexPage && !canonical.endsWith('/')) {
  canonical += '/';
}
const slug = Astro.params.slug;
---
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width"/>
  <link rel="icon" type="image/png" href="/img/favicon.png"/>
  { canonical && <link rel="canonical" href={canonical} /> }
  <meta name="algolia-site-verification" content="857638C054AD182F" />
  <link rel="sitemap" href="/sitemap-index.xml">
  <link rel="alternate" type="text/plain" title="LLM Index" href="/.well-known/llms.txt" />
  <Font cssVariable="--font-inter-var" preload />
  <script src="../scripts/ScrollSpy.ts"></script>
  <script src="../scripts/Visibility.ts"></script>
  {applyTheme && <script is:inline>
    const getTheme = () => {
      const theme = localStorage?.getItem('theme');
      if (theme && theme !== 'system') {
        return theme;
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    const applyThemeClass = () => {
      document.documentElement.classList.toggle('dark', getTheme() === 'dark');
    };

    // run immediately on initial load to prevent flashing
    applyThemeClass();
  </script>}
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta property="og:site_name" content="FusionAuth"/>
  <meta property="og:url" content={normalizedUrl}/>
  <meta property="og:description" content={description}/>
  <meta property="og:title" content={title}/>
  <meta property="og:type" content="website"/>
  <meta property="og:locale" content="en_US"/>
  <meta property="og:image" content={openGraphImageUrl}/>

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@FusionAuth">
  <meta name="twitter:creator" content="@FusionAuth">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={openGraphImageUrl}>

  {isProd && enableGTM &&
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MZ9FDPFDF0" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MZ9FDPFDF0');
    </script>
  }

  { enableBaseParent &&
    <base target="_parent"/>
  }
</head>
