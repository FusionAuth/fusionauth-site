---
interface Props {
  method: string;
  path: string;
  tag?: string;
}
const { method, path, tag = 'users' } = Astro.props;
const href = `/docs/apis/api-explorer#tag/${tag}/${method.toUpperCase()}${path}`;
---
<p class="not-prose my-4">
  <a
    href={href}
    class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-700 dark:text-indigo-400 hover:text-orange-700 dark:hover:text-orange-300 no-underline border-b border-indigo-700 dark:border-indigo-400 hover:border-orange-700 dark:hover:border-orange-300"
  >
    Try <code class="text-xs font-mono px-1 py-0.5 rounded bg-slate-100 dark:bg-slate-800">{method.toUpperCase()} {path}</code> in the API Explorer
    <span aria-hidden="true">&rarr;</span>
  </a>
</p>
