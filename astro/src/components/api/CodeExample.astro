---
import CopyToClipboard from 'src/components/CopyToClipboard.astro';
import { codeToHtml } from 'shiki';
import generatedSnippets from 'src/data/generated-snippets.json';

interface Props {
  method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
  uri: string;
  body?: string;
}

const { method, uri } = Astro.props;

const basePath = uri.split('?')[0];
const lookupKey = `${method} ${basePath}`;
const body: string | null = Astro.props.body ?? (generatedSnippets as Record<string, string | null>)[lookupKey] ?? null;

const uid = Math.random().toString(36).slice(2, 9);
const curlId = `curl-${uid}`;
const pythonId = `python-${uid}`;
const typescriptId = `typescript-${uid}`;
const goId = `go-${uid}`;
const javaId = `java-${uid}`;

const methodFlag = method === 'GET' ? '-G' : `-X ${method}`;
const quotedUri = uri.includes('&') ? `'https://your-fusionauth-host${uri}'` : `https://your-fusionauth-host${uri}`;

let curlSnippet = `curl ${methodFlag} \\
  ${quotedUri} \\
  -H "Authorization: YOUR_API_KEY"`;

if (body) {
  curlSnippet += ` \\\n  -H "Content-Type: application/json" \\\n  -d '${body}'`;
}

const pythonMethod = method.toLowerCase();
let pythonSnippet = `import requests

headers = {
    "Authorization": "YOUR_API_KEY",
}`;

if (body) {
  const bodyPython = JSON.stringify(JSON.parse(body), null, 4)
    .replace(/: true/g, ': True')
    .replace(/: false/g, ': False')
    .replace(/: null/g, ': None');

  pythonSnippet += `

body = ${bodyPython}

response = requests.${pythonMethod}(
    "https://your-fusionauth-host${uri}",
    headers=headers,
    json=body,
)`;
} else {
  pythonSnippet += `

response = requests.${pythonMethod}(
    "https://your-fusionauth-host${uri}",
    headers=headers,
)`;
}

pythonSnippet += `
print(response.json())`;

const bodyTs = body
  ? JSON.stringify(JSON.parse(body), null, 2).split('\n').join('\n    ')
  : null;

let typescriptSnippet = `const response = await fetch(
  "https://your-fusionauth-host${uri}",
  {
    method: "${method}",
    headers: {
      Authorization: "YOUR_API_KEY",${body ? `\n      "Content-Type": "application/json",` : ''}
    },${bodyTs ? `\n    body: JSON.stringify(${bodyTs}),` : ''}
  }
);

const data = await response.json();
console.log(data);`;

const bodyGoJson = body
  ? JSON.stringify(JSON.parse(body), null, 2).split('\n').join('\n\t')
  : null;

const goImports = body
  ? ['fmt', 'io', 'net/http', 'strings']
  : ['fmt', 'io', 'net/http'];

const goLines = [
  'package main',
  '',
  'import (',
  ...goImports.map((i) => `\t"${i}"`),
  ')',
  '',
  'func main() {',
];

if (body) {
  goLines.push(`\tbody := \`${bodyGoJson}\``);
  goLines.push('');
}

goLines.push(
  `\treq, _ := http.NewRequest("${method}", "https://your-fusionauth-host${uri}", ${body ? 'strings.NewReader(body)' : 'nil'})`,
  '\treq.Header.Set("Authorization", "YOUR_API_KEY")',
);
if (body) goLines.push('\treq.Header.Set("Content-Type", "application/json")');
goLines.push(
  '',
  '\tclient := &http.Client{}',
  '\tresp, _ := client.Do(req)',
  '\tdefer resp.Body.Close()',
  '',
  '\trespBody, _ := io.ReadAll(resp.Body)',
  '\tfmt.Println(string(respBody))',
  '}',
);

const goSnippet = goLines.join('\n');

const bodyJavaJson = body
  ? JSON.stringify(JSON.parse(body), null, 4).split('\n').join('\n            ')
  : null;

const javaLines = [
  'import java.net.URI;',
  'import java.net.http.HttpClient;',
  'import java.net.http.HttpRequest;',
  'import java.net.http.HttpResponse;',
  '',
  'public class Main {',
  '    public static void main(String[] args) throws Exception {',
  '        HttpClient client = HttpClient.newHttpClient();',
];

if (body) {
  javaLines.push(`        String body = """`, `            ${bodyJavaJson}`, `            """;`);
  javaLines.push('');
}

javaLines.push(
  '        HttpRequest request = HttpRequest.newBuilder()',
  `            .uri(URI.create("https://your-fusionauth-host${uri}"))`,
  '            .header("Authorization", "YOUR_API_KEY")',
);
if (body) {
  javaLines.push(
    '            .header("Content-Type", "application/json")',
    `            .${method === 'GET' ? 'GET()' : `method("${method}", HttpRequest.BodyPublishers.ofString(body))`}`,
  );
} else {
  javaLines.push(`            .${method === 'GET' ? 'GET()' : `method("${method}", HttpRequest.BodyPublishers.noBody())`}`);
}
javaLines.push(
  '            .build();',
  '',
  '        HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());',
  '        System.out.println(response.body());',
  '    }',
  '}',
);

const javaSnippet = javaLines.join('\n');

const shikiTheme = 'github-dark';

const curlHtml = await codeToHtml(curlSnippet, { lang: 'bash', theme: shikiTheme });
const pythonHtml = await codeToHtml(pythonSnippet, { lang: 'python', theme: shikiTheme });
const typescriptHtml = await codeToHtml(typescriptSnippet, { lang: 'typescript', theme: shikiTheme });
const goHtml = await codeToHtml(goSnippet, { lang: 'go', theme: shikiTheme });
const javaHtml = await codeToHtml(javaSnippet, { lang: 'java', theme: shikiTheme });

const snippets = [
  { lang: 'curl', label: 'curl', id: curlId, html: curlHtml, raw: curlSnippet },
  { lang: 'python', label: 'Python', id: pythonId, html: pythonHtml, raw: pythonSnippet },
  { lang: 'typescript', label: 'TypeScript', id: typescriptId, html: typescriptHtml, raw: typescriptSnippet },
  { lang: 'go', label: 'Go', id: goId, html: goHtml, raw: goSnippet },
  { lang: 'java', label: 'Java', id: javaId, html: javaHtml, raw: javaSnippet },
];
---

<div class="not-prose relative my-4 rounded bg-gray-800" data-code-example>
  <div class="flex items-center justify-between px-4 py-2 border-b border-gray-700">
    <div class="relative lang-dropdown" data-uid={uid}>
      <button
        class="lang-dropdown-btn flex items-center gap-1.5 px-3 py-1 rounded text-xs font-semibold text-white bg-gray-700 hover:bg-gray-600 border border-gray-600"
        aria-haspopup="listbox"
        aria-expanded="false"
      >
        <span class="lang-dropdown-label">{snippets[0].label}</span>
        <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <ul
        class="lang-dropdown-menu absolute left-0 top-full mt-1 z-10 hidden min-w-full rounded border border-gray-600 bg-gray-800 shadow-lg"
        role="listbox"
      >
        {snippets.map((s) => (
          <li
            class="lang-option px-3 py-1.5 text-xs font-semibold text-gray-300 hover:bg-gray-700 hover:text-white cursor-pointer first:rounded-t last:rounded-b"
            data-lang={s.lang}
            role="option"
          >
            {s.label}
          </li>
        ))}
      </ul>
    </div>
    <CopyToClipboard source={curlId} />
  </div>
  {snippets.map((s) => (
    <span id={s.id} class="hidden">{s.raw}</span>
  ))}
  {snippets.map((s, i) => (
    <div
      data-panel={s.lang}
      class={`[&>pre]:overflow-x-auto [&>pre]:px-4 [&>pre]:py-3 [&>pre]:text-sm [&>pre]:leading-relaxed [&>pre]:!bg-transparent [&>pre]:!m-0${i > 0 ? ' hidden' : ''}`}
      set:html={s.html}
    />
  ))}
</div>

<script>
  const STORAGE_KEY = 'fa-code-example-lang';

  function applyLang(container: Element, lang: string) {
    const dropdown = container.querySelector<HTMLElement>('.lang-dropdown');
    const copyButton = container.querySelector<HTMLElement>('[data-widget="copy-button"]');
    const panels = container.querySelectorAll<HTMLElement>('[data-panel]');

    const matchingPanel = container.querySelector<HTMLElement>(`[data-panel="${lang}"]`);
    if (!matchingPanel) return;

    panels.forEach((p) => p.classList.add('hidden'));
    matchingPanel.classList.remove('hidden');

    if (dropdown) {
      const option = dropdown.querySelector<HTMLElement>(`[data-lang="${lang}"]`);
      if (option) {
        dropdown.querySelector('.lang-dropdown-label')!.textContent = option.textContent;
      }
      const uid = dropdown.dataset.uid;
      if (copyButton) copyButton.dataset.copySource = `${lang}-${uid}`;
    }
  }

  function closeAllDropdowns() {
    document.querySelectorAll('.lang-dropdown-menu').forEach((m) => m.classList.add('hidden'));
    document.querySelectorAll('.lang-dropdown-btn').forEach((b) => b.setAttribute('aria-expanded', 'false'));
  }

  const containers = document.querySelectorAll('[data-code-example]');
  const savedLang = localStorage.getItem(STORAGE_KEY);

  containers.forEach((container) => {
    if (savedLang) applyLang(container, savedLang);

    const btn = container.querySelector<HTMLButtonElement>('.lang-dropdown-btn');
    const menu = container.querySelector<HTMLElement>('.lang-dropdown-menu');

    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu?.classList.contains('hidden') === false;
      closeAllDropdowns();
      if (!isOpen) {
        menu?.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
      }
    });

    container.querySelectorAll<HTMLElement>('.lang-option').forEach((option) => {
      option.addEventListener('click', () => {
        const lang = option.dataset.lang!;
        closeAllDropdowns();
        localStorage.setItem(STORAGE_KEY, lang);
        containers.forEach((c) => applyLang(c, lang));
      });
    });
  });

  document.addEventListener('click', closeAllDropdowns);
</script>
