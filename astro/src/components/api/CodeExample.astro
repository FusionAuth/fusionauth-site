---
import CopyToClipboard from 'src/components/CopyToClipboard.astro';
import { codeToHtml } from 'shiki';
import generatedSnippets from 'src/data/generated-snippets.json';

interface Props {
  method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
  uri: string;
  body?: string;
}

const { method, uri } = Astro.props;

const basePath = uri.split('?')[0];
const lookupKey = `${method} ${basePath}`;
const body: string | null = Astro.props.body ?? (generatedSnippets as Record<string, string | null>)[lookupKey] ?? null;

const uid = Math.random().toString(36).slice(2, 9);
const curlId = `curl-${uid}`;
const pythonId = `python-${uid}`;

const methodFlag = method === 'GET' ? '-G' : `-X ${method}`;
const quotedUri = uri.includes('&') ? `'https://your-fusionauth-host${uri}'` : `https://your-fusionauth-host${uri}`;

let curlSnippet = `curl ${methodFlag} \\
  ${quotedUri} \\
  -H "Authorization: YOUR_API_KEY"`;

if (body) {
  curlSnippet += ` \\\n  -H "Content-Type: application/json" \\\n  -d '${body}'`;
}

const pythonMethod = method.toLowerCase();
let pythonSnippet = `import requests

headers = {
    "Authorization": "YOUR_API_KEY",
}`;

if (body) {
  const bodyPython = JSON.stringify(JSON.parse(body), null, 4)
    .replace(/: true/g, ': True')
    .replace(/: false/g, ': False')
    .replace(/: null/g, ': None');

  pythonSnippet += `

body = ${bodyPython}

response = requests.${pythonMethod}(
    "https://your-fusionauth-host${uri}",
    headers=headers,
    json=body,
)`;
} else {
  pythonSnippet += `

response = requests.${pythonMethod}(
    "https://your-fusionauth-host${uri}",
    headers=headers,
)`;
}

pythonSnippet += `
print(response.json())`;

const shikiTheme = 'github-dark';

const curlHtml = await codeToHtml(curlSnippet, { lang: 'bash', theme: shikiTheme });
const pythonHtml = await codeToHtml(pythonSnippet, { lang: 'python', theme: shikiTheme });
---

<div class="not-prose relative my-4 rounded bg-gray-800" data-code-example>
  <div class="flex items-center justify-between px-4 py-2 border-b border-gray-700">
    <div class="flex gap-1">
      <button
        class="tab-btn px-3 py-1 rounded text-xs font-semibold text-white bg-indigo-600"
        data-lang="curl"
        data-target={curlId}
      >curl</button>
      <button
        class="tab-btn px-3 py-1 rounded text-xs font-semibold text-gray-400 hover:text-white"
        data-lang="python"
        data-target={pythonId}
      >Python</button>
    </div>
    <CopyToClipboard source={curlId} />
  </div>
  <span id={curlId} class="hidden">{curlSnippet}</span>
  <span id={pythonId} class="hidden">{pythonSnippet}</span>
  <div data-panel="curl" class="[&>pre]:overflow-x-auto [&>pre]:px-4 [&>pre]:py-3 [&>pre]:text-sm [&>pre]:leading-relaxed [&>pre]:!bg-transparent [&>pre]:!m-0" set:html={curlHtml} />
  <div data-panel="python" class="hidden [&>pre]:overflow-x-auto [&>pre]:px-4 [&>pre]:py-3 [&>pre]:text-sm [&>pre]:leading-relaxed [&>pre]:!bg-transparent [&>pre]:!m-0" set:html={pythonHtml} />
</div>

<script>
  const STORAGE_KEY = 'fa-code-example-lang';

  function applyLang(container: Element, lang: string) {
    const buttons = container.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const copyButton = container.querySelector<HTMLElement>('[data-widget="copy-button"]');
    const panels = container.querySelectorAll<HTMLElement>('[data-panel]');

    const targetBtn = Array.from(buttons).find((b) => b.dataset.lang === lang);
    if (!targetBtn) return;

    panels.forEach((p) => p.classList.add('hidden'));
    buttons.forEach((b) => {
      b.classList.remove('bg-indigo-600', 'text-white');
      b.classList.add('text-gray-400');
    });

    container.querySelector<HTMLElement>(`[data-panel="${lang}"]`)?.classList.remove('hidden');
    targetBtn.classList.add('bg-indigo-600', 'text-white');
    targetBtn.classList.remove('text-gray-400');

    if (copyButton) {
      copyButton.dataset.copySource = targetBtn.dataset.target!;
    }
  }

  const containers = document.querySelectorAll('[data-code-example]');
  const savedLang = localStorage.getItem(STORAGE_KEY);

  containers.forEach((container) => {
    if (savedLang) applyLang(container, savedLang);

    container.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang!;
        localStorage.setItem(STORAGE_KEY, lang);
        containers.forEach((c) => applyLang(c, lang));
      });
    });
  });
</script>
