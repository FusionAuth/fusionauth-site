---
import Aside from 'src/components/Aside.astro';

interface Props {
  since: string;
}

const { since }: Props = Astro.props;

if (!since) {
  throw new Error("DeprecatedEndpoint requires a `since` prop (e.g. since=\"1.64.0\")");
}
---

<Aside type="caution" title={`Deprecated since ${since}`}>
  <slot />
</Aside>