---
---
<div id="docsearch"></div>

<style is:global>
  /* Color variables matching FusionAuth site theme */
  :root {
    --docsearch-primary-color: #4f46e5;
    --docsearch-text-color: #334155;
    --docsearch-muted-color: #94a3b8;
    --docsearch-container-background: rgba(15, 23, 42, 0.5);
    --docsearch-modal-background: #fff;
    --docsearch-modal-shadow: 0 3px 8px rgba(15, 23, 42, 0.2);
    --docsearch-searchbox-background: #f1f5f9;
    --docsearch-searchbox-focus-background: #fff;
    --docsearch-searchbox-shadow: inset 0 0 0 2px #4f46e5;
    --docsearch-hit-color: #334155;
    --docsearch-hit-active-color: #fff;
    --docsearch-hit-background: #f1f5f9;
    --docsearch-hit-shadow: none;
    --docsearch-footer-background: #f8fafc;
    --docsearch-key-gradient: linear-gradient(-26.5deg, #e2e8f0, #f8fafc);
    --docsearch-key-shadow: inset 0 -2px 0 0 #cbd5e1, inset 0 0 1px 1px #fff, 0 1px 2px 1px rgba(15, 23, 42, 0.1);
  }

  html.dark {
    --docsearch-text-color: #e2e8f0;
    --docsearch-muted-color: #475569;
    --docsearch-container-background: rgba(15, 23, 42, 0.8);
    --docsearch-modal-background: #0f172a;
    --docsearch-modal-shadow: 0 3px 8px rgba(0, 0, 0, 0.4);
    --docsearch-searchbox-background: #1e293b;
    --docsearch-searchbox-focus-background: #0f172a;
    --docsearch-hit-color: #94a3b8;
    --docsearch-hit-background: #1e293b;
    --docsearch-footer-background: #1e293b;
    --docsearch-key-gradient: linear-gradient(-26.5deg, #1e293b, #334155);
    --docsearch-key-shadow: inset 0 -2px 0 0 #0f172a, inset 0 0 1px 1px #334155, 0 1px 2px 1px rgba(0, 0, 0, 0.4);
  }

  /* Trigger button styled to match the existing sidebar search button */
  #docsearch .DocSearch-Button {
    background-color: #fff;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 0.375rem;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    color: #94a3b8;
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    height: auto;
    margin: 0;
    padding: 6px 12px 6px 10px;
    width: 100%;
  }

  #docsearch .DocSearch-Button:hover,
  #docsearch .DocSearch-Button:focus {
    background-color: #fff;
    border-color: #cbd5e1;
    box-shadow: none;
    color: #94a3b8;
    outline: none;
  }

  html.dark #docsearch .DocSearch-Button {
    background-color: #1e293b;
    border-color: rgba(241, 245, 249, 0.1);
    color: #94a3b8;
  }

  html.dark #docsearch .DocSearch-Button:hover,
  html.dark #docsearch .DocSearch-Button:focus {
    background-color: #334155;
    border-color: #475569;
  }

  #docsearch .DocSearch-Button-Placeholder {
    font-size: 0.875rem;
    padding-right: 0;
  }

  #docsearch .DocSearch-Button .DocSearch-Search-Icon {
    color: #94a3b8;
    height: 1rem;
    margin-right: 0.75rem;
    width: 1rem;
  }

  #docsearch .DocSearch-Button-Keys {
    margin-left: auto;
    min-width: unset;
    padding-left: 0.75rem;
  }

  #docsearch .DocSearch-Button-Key {
    background: #f1f5f9;
    border: none;
    border-radius: 3px;
    box-shadow: none;
    color: #64748b;
    font-size: 0.625rem;
    font-weight: 600;
    height: 18px;
    line-height: 18px;
    padding: 0 4px;
  }

  html.dark #docsearch .DocSearch-Button-Key {
    background: #334155;
    color: #94a3b8;
  }
</style>

<script>
  import docsearch from '@docsearch/js';

  const SAMPLE_HITS = [
    {
      objectID: '1',
      url: '/docs/get-started/download-and-install',
      hierarchy: { lvl0: 'Getting Started', lvl1: 'Download and Install', lvl2: null, lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'System requirements and installation options for Linux, macOS, and Windows.',
      type: 'content',
    },
    {
      objectID: '2',
      url: '/docs/get-started/core-concepts/users',
      hierarchy: { lvl0: 'Getting Started', lvl1: 'Core Concepts', lvl2: 'Users', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'A user represents a person who has been registered with FusionAuth.',
      type: 'lvl2',
    },
    {
      objectID: '3',
      url: '/docs/quickstart/quickstart-javascript-react',
      hierarchy: { lvl0: 'Quickstarts', lvl1: 'React Quickstart', lvl2: 'Add Login to a React App', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Add authentication to a React application using FusionAuth in 5 minutes.',
      type: 'lvl2',
    },
    {
      objectID: '4',
      url: '/docs/quickstart/quickstart-javascript-nextjs',
      hierarchy: { lvl0: 'Quickstarts', lvl1: 'Next.js Quickstart', lvl2: 'Add Login to a Next.js App', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Add FusionAuth login to a Next.js application with server-side rendering.',
      type: 'lvl2',
    },
    {
      objectID: '5',
      url: '/docs/lifecycle/authenticate-users/oauth',
      hierarchy: { lvl0: 'Authentication', lvl1: 'OAuth & OIDC', lvl2: 'Authorization Code Grant', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'The Authorization Code grant is the most secure OAuth 2.0 flow for web applications.',
      type: 'content',
    },
    {
      objectID: '6',
      url: '/docs/lifecycle/authenticate-users/saml',
      hierarchy: { lvl0: 'Authentication', lvl1: 'SAML', lvl2: 'Configure SAML', lvl3: 'Identity Provider Configuration', lvl4: null, lvl5: null, lvl6: null },
      content: 'Configure FusionAuth as a SAML Identity Provider to enable SSO with service providers.',
      type: 'content',
    },
    {
      objectID: '7',
      url: '/docs/apis/users',
      hierarchy: { lvl0: 'API Reference', lvl1: 'Users API', lvl2: 'Retrieve a User', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Retrieve a user by Id, username, email address, or JWT. GET /api/user.',
      type: 'content',
    },
    {
      objectID: '8',
      url: '/docs/apis/applications',
      hierarchy: { lvl0: 'API Reference', lvl1: 'Applications API', lvl2: null, lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'An Application represents an application that a user can be registered to within FusionAuth.',
      type: 'lvl1',
    },
    {
      objectID: '9',
      url: '/docs/customize/look-and-feel/themes',
      hierarchy: { lvl0: 'Customization', lvl1: 'Themes', lvl2: 'Advanced Themes', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Customize FusionAuth login pages using FreeMarker templates and Tailwind CSS.',
      type: 'content',
    },
    {
      objectID: '10',
      url: '/docs/customize/email-and-messages/email-templates',
      hierarchy: { lvl0: 'Customization', lvl1: 'Email Templates', lvl2: 'Password Reset Email', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Customize the password reset email sent to users using FreeMarker templates.',
      type: 'content',
    },
    {
      objectID: '11',
      url: '/docs/operate/secure-and-monitor/security',
      hierarchy: { lvl0: 'Operations', lvl1: 'Security', lvl2: 'Breached Password Detection', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Detect and prevent use of breached passwords using the HaveIBeenPwned database.',
      type: 'content',
    },
    {
      objectID: '12',
      url: '/docs/lifecycle/manage-users/multi-factor-authentication',
      hierarchy: { lvl0: 'User Management', lvl1: 'Multi-Factor Authentication', lvl2: 'TOTP', lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Enable time-based one-time passwords (TOTP) for two-factor authentication.',
      type: 'content',
    },
    {
      objectID: '13',
      url: '/docs/lifecycle/authenticate-users/login-api',
      hierarchy: { lvl0: 'Authentication', lvl1: 'Login API', lvl2: null, lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Use the Login API to authenticate users from your own login form instead of the hosted pages.',
      type: 'lvl1',
    },
    {
      objectID: '14',
      url: '/docs/operate/deploy/configuration-reference',
      hierarchy: { lvl0: 'Operations', lvl1: 'Configuration Reference', lvl2: null, lvl3: null, lvl4: null, lvl5: null, lvl6: null },
      content: 'Complete reference for all FusionAuth configuration options in fusionauth.properties.',
      type: 'lvl1',
    },
  ];

  function highlight(text: string | null, query: string): string {
    if (!text || !query) return text || '';
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
  }

  function makeHit(hit: typeof SAMPLE_HITS[0], query: string) {
    const hierarchyHighlight: Record<string, { value: string; matchLevel: string; matchedWords: string[] }> = {};
    for (const [k, v] of Object.entries(hit.hierarchy)) {
      if (v) {
        hierarchyHighlight[k] = {
          value: highlight(v, query),
          matchLevel: v.toLowerCase().includes(query.toLowerCase()) ? 'full' : 'none',
          matchedWords: query ? [query] : [],
        };
      }
    }
    return {
      ...hit,
      _highlightResult: {
        hierarchy: hierarchyHighlight,
        ...(hit.content ? {
          content: {
            value: highlight(hit.content, query),
            matchLevel: hit.content.toLowerCase().includes(query.toLowerCase()) ? 'full' : 'none',
            matchedWords: query ? [query] : [],
          },
        } : {}),
      },
      _snippetResult: hit.content ? {
        content: {
          value: highlight(hit.content, query),
          matchLevel: hit.content.toLowerCase().includes(query.toLowerCase()) ? 'full' : 'none',
        },
      } : undefined,
    };
  }

  const mockSearchClient = {
    search(requests: Array<{ query: string }>) {
      return Promise.resolve({
        results: requests.map((req) => {
          const query = (req.query || '').toLowerCase().trim();
          const hits = (query
            ? SAMPLE_HITS.filter((h) =>
                Object.values(h.hierarchy).some((v) => v && v.toLowerCase().includes(query)) ||
                (h.content || '').toLowerCase().includes(query)
              )
            : SAMPLE_HITS.slice(0, 5)
          ).map((h) => makeHit(h, req.query || ''));
          return {
            hits,
            nbHits: hits.length,
            page: 0,
            nbPages: 1,
            hitsPerPage: 20,
            exhaustiveNbHits: true,
            query: req.query,
            params: '',
            processingTimeMS: 1,
          };
        }),
      });
    },
  };

  docsearch({
    container: '#docsearch',
    // @ts-ignore – mock client satisfies the required interface at runtime
    searchClient: mockSearchClient,
    indexName: 'fusionauth',
    placeholder: 'Search docs...',
    detachedMediaQuery: 'all',
  });

  // Wire mobile/header search buttons to open the DocSearch modal
  const wireButtons = () => {
    document.querySelectorAll<HTMLElement>('[data-widget="search-button"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelector<HTMLButtonElement>('.DocSearch-Button')?.click();
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', wireButtons);
  } else {
    wireButtons();
  }
</script>
