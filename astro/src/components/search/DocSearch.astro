---
import '@docsearch/css';
---
<div id="docsearch"></div>

<style is:global>
  :root {
    /* Primary accent (indigo-600) */
    --docsearch-primary-color: #4f46e5;
    --docsearch-highlight-color: #4f46e5;
    --docsearch-focus-color: #4f46e5;
    /* Text */
    --docsearch-text-color: #334155;
    --docsearch-secondary-text-color: #64748b;
    --docsearch-muted-color: #94a3b8;
    /* Surfaces */
    --docsearch-container-background: rgba(15, 23, 42, 0.5);
    --docsearch-modal-background: #fff;
    --docsearch-modal-shadow: 0 3px 8px rgba(15, 23, 42, 0.2);
    --docsearch-searchbox-background: #f1f5f9;
    --docsearch-searchbox-focus-background: #fff;
    --docsearch-footer-background: #f8fafc;
    /* Hits */
    --docsearch-hit-color: #334155;
    --docsearch-hit-background: #f1f5f9;
    --docsearch-hit-highlight-color: rgba(79, 70, 229, 0.1);
    /* Keys */
    --docsearch-key-background: #f1f5f9;
    --docsearch-key-color: #64748b;
    /* Borders */
    --docsearch-subtle-color: #e2e8f0;
    /* Button */
    --docsearch-search-button-background: #fff;
    --docsearch-search-button-text-color: #94a3b8;
  }

  html.dark {
    /* Primary accent (indigo-400 for dark) */
    --docsearch-highlight-color: #818cf8;
    --docsearch-focus-color: #a5b4fc;
    /* Text — all must meet 4.5:1 on #1e293b (slate-800) */
    --docsearch-text-color: #e2e8f0;
    --docsearch-secondary-text-color: #94a3b8;
    --docsearch-muted-color: #94a3b8;
    /* Surfaces */
    --docsearch-container-background: rgba(15, 23, 42, 0.8);
    --docsearch-modal-background: #0f172a;
    --docsearch-modal-shadow: 0 3px 8px rgba(0, 0, 0, 0.4);
    --docsearch-searchbox-background: #1e293b;
    --docsearch-searchbox-focus-background: #0f172a;
    --docsearch-footer-background: #1e293b;
    /* Hits */
    --docsearch-hit-color: #cbd5e1;
    --docsearch-hit-background: #1e293b;
    --docsearch-hit-highlight-color: rgba(129, 140, 248, 0.15);
    /* Keys */
    --docsearch-key-background: #334155;
    --docsearch-key-color: #94a3b8;
    /* Borders */
    --docsearch-subtle-color: #334155;
    /* Button */
    --docsearch-search-button-background: #1e293b;
    --docsearch-search-button-text-color: #94a3b8;
  }

  #docsearch {
    min-width: 0;
    width: 100%;
  }

  #docsearch .DocSearch-Button {
    background-color: #fff;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 0.375rem;
    box-sizing: border-box;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    color: #94a3b8;
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    height: auto;
    margin: 0;
    padding: 6px 12px 6px 10px;
    width: 100%;
  }

  #docsearch .DocSearch-Button-Container {
    min-width: 0;
  }

  #docsearch .DocSearch-Button:hover,
  #docsearch .DocSearch-Button:focus {
    background-color: #fff;
    border-color: #cbd5e1;
    box-shadow: none;
    color: #94a3b8;
    outline: none;
  }

  html.dark #docsearch .DocSearch-Button {
    background-color: #1e293b;
    border-color: rgba(241, 245, 249, 0.1);
    color: #94a3b8;
  }

  html.dark #docsearch .DocSearch-Button:hover,
  html.dark #docsearch .DocSearch-Button:focus {
    background-color: #334155;
    border-color: #475569;
  }

  #docsearch .DocSearch-Button-Placeholder {
    font-size: 0.875rem;
    overflow: hidden;
    padding-right: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #docsearch .DocSearch-Button .DocSearch-Search-Icon {
    color: #94a3b8;
    height: 1rem;
    margin-right: 0.75rem;
    width: 1rem;
  }

  #docsearch .DocSearch-Button-Keys {
    flex-shrink: 0;
    margin-left: auto;
    min-width: unset;
    padding-left: 0.75rem;
  }

  #docsearch .DocSearch-Button-Key {
    background: #f1f5f9;
    border: none;
    border-radius: 3px;
    box-sizing: border-box;
    box-shadow: none;
    color: #64748b;
    font-size: 0.625rem;
    font-weight: 600;
    height: 18px;
    line-height: 18px;
    padding: 0 4px;
  }

  html.dark #docsearch .DocSearch-Button-Key {
    background: #334155;
    color: #94a3b8;
  }
</style>

<script>
  import docsearch from '@docsearch/js';
  import { algoliaConfig } from 'src/config';

  const urlDepth = (url: string) => (url.match(/\//g) || []).length;

  const options = {
    container: '#docsearch',
    ...algoliaConfig,
    placeholder: 'Search docs...',
    detachedMediaQuery: 'all',
    transformItems: (items: any[]) => {
      const filtered = items.filter((item) => !/\/(tag|author|category)\//.test(item.url));
      const path = window.location.pathname;
      let primaryFilter: (url: string) => boolean;

      if (path.startsWith('/articles')) {
        primaryFilter = (url) => url.includes('/articles/');
      } else if (path.startsWith('/blog')) {
        primaryFilter = (url) => url.includes('/blog/');
      } else {
        primaryFilter = (url) => url.includes('/docs/');
      }

      const primary = filtered
        .filter((item) => primaryFilter(item.url))
        .sort((a, b) => urlDepth(a.url) - urlDepth(b.url));
      const docs = filtered
        .filter((item) => !primaryFilter(item.url) && item.url.includes('/docs/'))
        .sort((a, b) => urlDepth(a.url) - urlDepth(b.url));
      const rest = filtered.filter((item) => !primaryFilter(item.url) && !item.url.includes('/docs/'));
      const sorted = [...primary, ...docs, ...rest];

      // For every docs page-level hit (type=lvl1): move the section name (lvl0)
      // into the subtitle position (lvl1) and collapse the group header to
      // "Documentation". This gives every result a section breadcrumb without
      // any duplicate-counting logic, and requires no crawler changes.
      const normalised = sorted.map((item) => {
        const section = item.hierarchy?.lvl0;
        if (!section || section === 'Blog' || section === 'Articles') return item;

        // Collapse group header → "Documentation" for all docs hits.
        const base = {
          ...item,
          hierarchy: { ...item.hierarchy, lvl0: 'Documentation' },
          _highlightResult: item._highlightResult ? {
            ...item._highlightResult,
            hierarchy: { ...item._highlightResult.hierarchy, lvl0: { value: 'Documentation', matchLevel: 'none', matchedWords: [] } },
          } : item._highlightResult,
        };

        // Promote page-level hits to lvl2 so DocSearch renders
        // the section name as the subtitle beneath the page title.
        if (item.type !== 'lvl1' || item.hierarchy.lvl2) return base;
        return {
          ...base,
          type: 'lvl2',
          hierarchy: { ...base.hierarchy, lvl1: section, lvl2: item.hierarchy.lvl1 },
          _highlightResult: base._highlightResult ? {
            ...base._highlightResult,
            hierarchy: {
              ...base._highlightResult.hierarchy,
              lvl1: { value: section, matchLevel: 'none', matchedWords: [] },
              lvl2: base._highlightResult.hierarchy?.lvl1,
            },
          } : base._highlightResult,
          _snippetResult: item._snippetResult ? {
            ...item._snippetResult,
            hierarchy: {
              ...item._snippetResult.hierarchy,
              lvl1: { value: section, matchLevel: 'none', matchedWords: [] },
              lvl2: item._snippetResult.hierarchy?.lvl1,
            },
          } : item._snippetResult,
        };
      });

      if (import.meta.env.DEV) {
        return normalised.map((item) => ({
          ...item,
          url: item.url.replace(/^https?:\/\/[^/]+/, window.location.origin),
        }));
      }

      return normalised;
    },
  };

  const openDocSearch = () => {
    document.querySelector<HTMLButtonElement>('.DocSearch-Button')?.click();
  };

  const init = () => {
    const container = document.getElementById('docsearch');
    if (!container) return;

    docsearch(options);
    document
      .querySelectorAll<HTMLElement>('[data-widget="search-button"]')
      .forEach((button) => button.addEventListener('click', openDocSearch));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
