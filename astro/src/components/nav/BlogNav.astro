---
import Nav from './ComposableNav.astro';

const categoryItems = [
  {name: 'Tutorials', href: '/blog/category/tutorial/'},
  {name: 'Release Updates', href: '/blog/category/release-updates/'},
  {name: 'Features', href: '/blog/category/product/'},
  {name: 'Comparison', href: '/blog/category/compare/'},
  {name: 'Customers', href: '/blog/category/customers/'},
  {name: 'Community', href: '/blog/category/community/'},
  {name: 'Education', href: '/blog/category/education/'},
  {name: 'News', href: '/blog/category/news/'},
];

const moreItems = [
  {name: 'Docs', href: '/docs/'},
  {name: 'Quickstarts', href: '/docs/quickstarts'},
  {name: 'Articles', href: '/articles'},
  {name: 'Blog', href: '/blog/'},
  {name: 'Developer Tools', href: '/dev-tools'},
  {name: 'Release Notes', href: '/docs/release-notes'},
  {name: 'Download', href: '/download'},
];

// order matters for the buttons
const buttons: {key: string, mobile?: boolean}[] = [
  {key: 'divider'}
];
if (Astro.props.darkModeToggle) {
  buttons.push({key: 'dark-mode', mobile: true});
}
buttons.push(
  {key: 'search', mobile: true},
  {key: 'login'},
  {key: 'expert'},
);

---
<Nav sectionTitle="Blog"
     sectionTitleHref="/blog"
     categoryLabel="Categories"
     categoryItems={categoryItems}
     moreItems={moreItems}
     buttons={buttons}
     colorThemeOverride="dark"
     noSideNav={true} />
