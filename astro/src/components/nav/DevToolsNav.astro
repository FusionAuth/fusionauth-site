---
import Nav from './ComposableNav.astro';

const categoryItems = [
  {name: 'Get Started', href: '/docs/get-started'},
  {name: 'Lifecycle', href: '/docs/lifecycle'},
  {name: 'Customize', href: '/docs/customize'},
  {name: 'Extend', href: '/docs/extend'},
  {name: 'Operate', href: '/docs/operate'},
  {name: 'SDKs', href: '/docs/sdks'},
  {name: 'APIs', href: '/docs/apis'},
  {name: 'Release Notes', href: '/docs/release-notes'},
  {name: 'Reference', href: '/docs/reference'},
];

const moreItems = [
  {name: 'Quickstarts', href: '/docs/quickstarts'},
  {name: 'Downloads', href: '/download'},
  {name: 'Blog', href: '/blog/'},
  {name: 'Articles', href: '/articles/'},
  {name: 'Developer Tools', href: '/dev-tools/'},
  {name: 'Docs', href: '/docs/'},
];

const buttons: {key: string, mobile?: boolean}[] = [
  {key: 'divider'},
  {key: 'dark-mode', mobile: true},
  {key: 'search', mobile: true},
  {key: 'login'},
  {key: 'expert'},
];
---
<Nav sectionTitle="Dev Tools"
     sectionTitleHref="/dev-tools/"
     categoryLabel="Categories"
     categoryItems={categoryItems}
     moreItems={moreItems}
     buttons={buttons}
     colorThemeOverride="dark"
     noSideNav={true}/>