---
import Icon from './icon/Icon.astro';

import { Icon as AIcon } from 'astro-iconify';

const themes = [
  {
    id: 'light',
    icon: 'sun',
    name: 'Light',
  },
  {
    id: 'dark',
    icon: 'moon',
    name: 'Dark'
  },
  {
    id: 'system',
    pack: 'fa7-solid',
    icon: 'computer',
    name: 'System',
  }
]
---
<div data-widget="theme-selector" class="relative z-10">
  <button type="button" class="flex items-center border-slate-500 rounded-lg  hover:text-slate-700  dark:hover:text-slate-300 border-0 mt-0 p-0 text-slate-400 w-auto dark:hover:bg-transparent hover:bg-transparent">
    <span class="text-lg mx-2"><Icon name="moon"></Icon></span>
  </button>

  <!-- Theme dropdown menu -->
  <ul class="absolute bg-white border border-slate-900/10 hidden rounded-md shadow-lg top-12 w-36 dark:bg-slate-900 dark:border-slate-100/10 dark:text-slate-200 left-auto right-0">
    {themes.map((theme) => (
      <li class="group">
        <div class="dark:group-[.active]:bg-slate-800 group-[.active]:bg-slate-100">
          <button type="button" class="flex font-medium group items-center gap-2 px-2 py-1 text-sm text-slate-900 w-full dark:text-indigo-200 dark:group-[.active]:text-indigo-400 group-[.active]:text-indigo-600" data-theme={theme.id}>
            <AIcon pack={theme.pack ?? 'fa7-regular'} name={theme.icon} width={22} height={22} class="text-slate-500 dark:group-[.active]:text-indigo-400 group-[.active]:text-indigo-600" />
            {theme.name}
          </button>
        </div>
      </li>
    ))}
  </ul>
</div>
