---
import { Icon } from "astro-iconset/components";
import MoonIcon from "src/components/icon/MoonIcon.astro";

const themes = [
  {
    id: 'light',
    icon: 'sun',
    name: 'Light',
    group: 'group-[.is-light]:opacity-75'
  },
  {
    id: 'dark',
    icon: 'moon',
    name: 'Dark',
    group: 'group-[.is-dark]:opacity-75'
  },
  {
    id: 'system',
    pack: 'fa7-solid',
    icon: 'computer',
    name: 'System',
    group: 'group-[.is-system]:opacity-75'
  }
]
---
<fa-theme-selector class="block relative z-10 group">
  
  <!-- MOBILE TOGGLE BUTTON -->
  <button id="mobile-theme-toggle" type="button" aria-label="Toggle Theme"
          class="flex lg:hidden items-center justify-center h-7 w-7 rounded hover:bg-gray-700 text-white transition-colors">
    <span class="hidden dark:block"><Icon name="fa7-solid:sun" width={20} height={20} /></span>
    <span class="block dark:hidden"><Icon name="fa7-solid:moon" width={20} height={20} /></span>
  </button>

  <!-- DESKTOP DROPDOWN BUTTON -->
  <button id="desktop-theme-button" type="button" aria-label="Theme Selector"
          class="hidden lg:flex items-center justify-center h-7 w-7 rounded hover:text-indigo-800 text-white transition-colors">
    <MoonIcon class="h-5 w-5" />
  </button>

  <!-- Theme dropdown menu (Desktop Only) -->
  <ul class="absolute bg-white border border-slate-500 dark:border-slate-800 hidden rounded-md shadow-xl top-12 w-36 dark:bg-slate-900 dark:text-slate-200 left-auto right-0 group lg:overflow-hidden m-0 p-0 flex flex-col">
    {themes.map((theme) => (
      <li class="m-0 p-0">
        <button type="button" class="flex font-medium items-center gap-2 px-3 py-2 text-sm text-slate-900 w-full dark:text-slate-200 focus:outline-hidden hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" data-theme={theme.id}>
          <Icon name={`${theme.pack ?? 'fa7-regular'}:${theme.icon}`} width={22} height={22} class:list={['opacity-35', theme.group] } />
          {theme.name}
        </button>
      </li>
    ))}
  </ul>
</fa-theme-selector>

<script>
  type Theme = 'system' | 'dark' | 'light';

  class ThemeSelector extends HTMLElement {
    private darkMatchMedia: MediaQueryList;
    private open = false;
    private desktopButton: HTMLElement | null = null;
    private mobileButton: HTMLElement | null = null;
    private themeButtons: HTMLButtonElement[] = [];
    private menu: HTMLElement | null = null;
    private currentTheme: Theme | null = null;

    private closeMenuFn = this.closeMenu.bind(this);
    private handleKeyDownFn = this.handleKeyDown.bind(this);

    connectedCallback() {
      this.currentTheme = (localStorage.getItem('theme') ?? 'system') as Theme;
      this.darkMatchMedia = window.matchMedia('(prefers-color-scheme: dark)');

      this.menu = this.querySelector('ul');
      this.menu.classList.add(`is-${this.currentTheme}`);
      
      this.desktopButton = this.querySelector('#desktop-theme-button');
      this.mobileButton = this.querySelector('#mobile-theme-toggle');
      this.themeButtons = Array.from(this.menu.querySelectorAll('ul button'));

      // Bind the respective buttons
      this.desktopButton?.addEventListener('click', this.handleMenu.bind(this));
      this.mobileButton?.addEventListener('click', this.handleMobileToggle.bind(this));
      
      this.themeButtons.forEach(button => {
        button.addEventListener('click', this.handleThemeChange.bind(this));
        button.addEventListener('mouseenter', this.handleThemeHover.bind(this));
      });
      
      this.darkMatchMedia.addEventListener('change', this.handlePrefersColorSchemaChange.bind(this));
      window.addEventListener('storage', this.handleStorageChange.bind(this));
    }

    disconnectedCallback() {
      window.removeEventListener('storage', this.handleStorageChange.bind(this));
      this.closeMenu();
    }
    
    handleMobileToggle(event: Event) {
      event.preventDefault();
      event.stopPropagation();
      
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      this.menu.classList.remove(`is-${this.currentTheme}`);
      this.menu.classList.add(`is-${newTheme}`);
      this.currentTheme = newTheme;
      
      localStorage.setItem('theme', newTheme);
      this.changeTheme(newTheme);
    }

    handleMenu(event: Event) {
      event.stopPropagation();
      event.preventDefault();
      if (this.open) {
        this.closeMenu();
        return;
      }
      this.openMenu();
    }

    openMenu() {
      if (this.open) return;
      document.addEventListener('click', this.closeMenuFn);
      document.addEventListener('keydown', this.handleKeyDownFn);
      this.menu.classList.remove('hidden');
      this.open = true;
    }

    closeMenu(event?: Event) {
      if (!this.open) return;
      if (event && this.contains(event.target as Node)) return;

      document.removeEventListener('click', this.closeMenuFn);
      document.removeEventListener('keydown', this.handleKeyDownFn);
      this.menu.classList.add('hidden');
      this.open = false;
    }

    handlePrefersColorSchemaChange() {
      if (localStorage.getItem('theme') !== 'system') return;
      this.changeTheme('system');
    }

    handleThemeHover(event: Event) {
      const target = event.currentTarget as HTMLButtonElement;
      target.focus();
    }

    handleThemeChange(event: Event) {
      const target = event.currentTarget as HTMLButtonElement;
      const theme = target.dataset.theme as Theme;
      if (theme) {
        localStorage.setItem('theme', theme);
        this.menu.classList.remove(`is-${this.currentTheme}`);
        this.menu.classList.add(`is-${theme}`);
        this.currentTheme = theme;
        this.changeTheme(theme as Theme);
      }
    }

    changeTheme(theme: Theme) {
      if (theme === 'system') {
        theme = this.darkMatchMedia.matches ? 'dark' : 'light';
      }
      document.documentElement.classList.toggle('dark', theme === 'dark');
      this.closeMenu();
    }

    handleKeyDown(event: KeyboardEvent) {
      if (event.key === 'Escape' || event.key === 'Tab') {
        this.closeMenu();
        return;
      }

      if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
        event.stopPropagation();
        event.preventDefault();

        const buttons = Array.from(this.themeButtons);
        const currentIndex = buttons.indexOf(event.target as HTMLButtonElement);
        const nextIndex = event.key === 'ArrowDown' ? currentIndex + 1 : currentIndex - 1;
        const nextButton = buttons[nextIndex < 0 ? buttons.length - 1 : nextIndex % buttons.length];
        nextButton.focus();
        return;
      }
    }

    handleStorageChange(event: StorageEvent) {
      if (event.key === 'theme') {
        this.currentTheme = event.newValue as Theme;
        this.changeTheme(this.currentTheme);
      }
    }
  }

  customElements.define('fa-theme-selector', ThemeSelector);
</script>