---
interface Props {
  image?: string;
  right?: boolean;
  className?: string
}

const {image, right=true, className } = Astro.props
---

<div class:list={["promo-gradient relative min-h-64 overflow-hidden text-white p-10 mb-8 rounded-md not-prose", (right ? 'md:pr-66' : ''), className]}> 
  <slot />
  <img src={image} class="image-slot image-right" />
</div>


<style>
  @reference "tailwindcss";
  .promo-gradient {
    background-image: linear-gradient(45deg, #12162f, #3f2a93 30%, #6e5cc6);

  }  
  .image-slot {
    @apply w-64 absolute hidden md:block visible;
  }
  .image-right {
    @apply -bottom-2 right-0;
  }
  .image-left {
    @apply -bottom-2 left-0;
  }
</style>