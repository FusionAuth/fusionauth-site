        <div class="flex-auto w-full sm:w-auto">
          <input type="email" id="mktoEmail" placeholder="Email address *" aria-label="Email address" required
            class="min-w-0 w-full rounded-md border-0 bg-slate-100 px-3.5 py-2 dark:bg-white/5 text-slate-600 dark:text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-indigo-500 sm:text-sm sm:leading-6 placeholder:text-gray-500" />
        </div>
        <button type="submit"
          class="flex-none rounded-md bg-indigo-500 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500 w-full sm:w-auto">Submit</button>
