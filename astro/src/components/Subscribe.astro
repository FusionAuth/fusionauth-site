<form id="mktoForm_1148" style="display:none;"></form>

<script is:inline src="https://195-ZDI-012.mktoweb.com/js/forms2/js/forms2.min.js" charset="utf-8"></script>
<script is:inline>
  (function initMarketo() {
    var customForm = document.getElementById("mktoForm_custom");
    
    // if script blocked, show a default error message on submit
    if (typeof MktoForms2 === "undefined") {
      customForm.addEventListener("submit", function(e) {
        e.preventDefault();
        customForm.querySelector(".error-message").style.display = "block";
      });
    } else {
      MktoForms2.loadForm("//195-ZDI-012.mktoweb.com", "195-ZDI-012", 1148, function(mktoForm) {
        mktoForm.onSuccess(function(values, followUpUrl) {
          customForm.querySelector(".form-fields").style.display = "none";
          customForm.querySelector(".error-message").style.display = "none";
          customForm.querySelector(".success-message").style.display = "block";
        });

        customForm.addEventListener("submit", function(e) {
          e.preventDefault(); 
          var email = document.getElementById("mktoEmail").value;
          mktoForm.setValues({ Email: email });
          mktoForm.submit();
        });
      });
    }
  })();
</script>