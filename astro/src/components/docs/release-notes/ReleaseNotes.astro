---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import ReleaseNotesItem from './ReleaseNotesItem.astro';

export const categories = [
  { id: 'theme-upgrade', label: 'Theme Upgrade', color: '#e11d48' },
  { id: 'new-feature', label: 'New Feature', color: '#16a34a' },
  { id: 'enhancement', label: 'Enhancement', color: '#2563eb' },
  { id: 'known-issue', label: 'Known Issue', color: '#bb4448' },
  { id: 'deprecated', label: 'Deprecated', color: '#ffcc48' },
  { id: 'fix', label: 'Fix', color: '#d97706' },
  { id: 'security', label: 'Security', color: '#566f98' },
  { id: 'internal', label: 'Internal', color: '#71717a' },
  { id: 'sdk', label: 'SDK', color: '#d98fd9'},
  { id: 'breaking-change', label: 'Breaking Change', color: '#aaaa33'},
  { id: 'database-migration', label: 'Database Migration', color: '#aa1d48' },
];

export const getCategoryLabel = (id: string) => {
  const category = categories.find((cat) => cat.id === id);
  if (category) return category.label;

  // Fallback logic for typos and mistakes: "new-feature" -> "New Feature"
  return id
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

const allUpdates = await getCollection('releases');
const updates = allUpdates.sort((a, b) => {
  // Sort by date
  const dateDiff = b.data.date.valueOf() - a.data.date.valueOf();
  if (dateDiff !== 0) return dateDiff;
  
  // Resolve date ties by version (e.g., 1.58.1 and 1.58.2)
  return b.data.version.localeCompare(a.data.version, undefined, { numeric: true });
});

// Dynamically generate styles for filtering logic and colored badges
const categoryStyles = categories.map(cat => `
  /* Filtering display logic */
  .release-container:has(#toggle-${cat.id}:checked) .release-notes-item-${cat.id} {
    display: block;
  }
  @media (width > 48rem) {
    .release-container:has(#toggle-${cat.id}:checked) .release-notes-item-${cat.id} {
      display: flex;
    }
  }

  /* Active chip color override */
  .filter-chip:has(#toggle-${cat.id}:checked) {
    background-color: ${cat.color} !important;
    border-color: ${cat.color} !important;
    color: #fff !important;
  }

  /* Release item badge colors */
  .badge-${cat.id} {
    background-color: ${cat.color}22;
    color: ${cat.color};
    border: 1px solid ${cat.color}44;
  }
`).join('\n');
---

<div class="release-container">
  <nav class="filter-controls lg:sticky lg:top-30 z-11 py-1 bg-white dark:bg-slate-900">
    {categories.map(cat => (
      <label class="filter-chip">
        <input type="checkbox" id={`toggle-${cat.id}`} class="filter-input" />
        <span>{cat.label}</span>
      </label>
    ))}
  </nav>

  <div class="version-list">
    {updates.map(async (item) => {
      const { Content } = await render(item);
      return (
        <article id={`version-${item.data.version.replaceAll('.', '-')}`} class="version relative">
          
          <header class="sticky lg:top-52 top-24 z-10 flex flex-wrap items-baseline justify-between py-3 mb-2 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
            
            <h2 class="release-note group m-0">
              Version {item.data.version} {item.data.name && `(${item.data.name})`}
              <a class="anchor-link !border-b-0 !no-underline ml-2 opacity-0 group-hover:opacity-100 transition-opacity" title="copy header link" href={`#version-${item.data.version.replaceAll('.', '-')}`}>#</a>
            </h2>
            
            <i class="version-date text-slate-500 text-sm">
              {item.data.date.toLocaleDateString("en-UK", { year: "numeric", month: "long", day: "numeric" })}
            </i>
          </header>
          
          <div class="content"><Content components={{ ReleaseNotesItem }} /></div>
        </article>
      );
    })}
  </div>
</div>

<Fragment set:html={`<style>${categoryStyles}</style>`} />

<style is:global>
  @reference "tailwindcss";

  /* scroll padding to work around stickies */
  html:has(.release-container) {
    scroll-padding-top: 100px;
    scroll-behavior: smooth;
  }

  @media (min-width: 1024px) {
    html:has(.release-container) {
      scroll-padding-top: 240px; /* Adjust this pixel height to match your sticky header stack */
    }
  }

  /* Hide all items if ANY filter is active, unless explicitly shown by the dynamic category CSS */
  .release-container:has(.filter-input:checked) [class*="release-notes-item-"] {
    @apply hidden;
  }

  .filter-controls {
    @apply flex flex-wrap gap-3;
    
    input {
      @apply hidden;
    }
  }

  .filter-chip {
    @apply 
      py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition ease-in-out
      opacity-70 grayscale
      text-slate-700 bg-slate-100 border border-slate-300
      dark:text-slate-300 dark:bg-slate-800 dark:border-slate-700;

    span {
      color: inherit;
    }
  }

  .filter-chip:hover {
    @apply brightness-95 dark:brightness-110;
  }

  .filter-chip:has(input:checked) {
    @apply grayscale-0 opacity-100 shadow-sm dark:shadow-none;
  }
</style>