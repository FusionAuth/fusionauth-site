---
import { categories, getCategoryLabel } from 'src/components/docs/release-notes/ReleaseNotes.astro';

export interface Props {
  issue?: string;
  bonusIssue? : string;
  thanks?: string;
  bonusThanks?: string;
  category: string;
  resolvedIn?: string;
  viaIssue?: string;
}

const { issue, bonusIssue, thanks, bonusThanks, resolvedIn, viaIssue, category = 'fix' } = Astro.props as Props;

const label = getCategoryLabel(category);
---
<div class={`issue-row release-notes-item-${category}`}>
  <span class={`issue-badge badge-${category}`}>
    {label}
  </span>

  <div class="issue-content">
    <div class="markdown-wrapper">
      <slot />
      {
        resolvedIn && viaIssue && (
          <p class="markdown-wrapper prose">
            Resolved in version <code>{resolvedIn}</code> via
            <a 
              target="_blank" 
              rel="noopener noreferrer" 
              href={`https://github.com/FusionAuth/fusionauth-issues/issues/${viaIssue}`}
            >
              #{viaIssue}
            </a>
          .
        </p>
        )
      }
      {thanks && <span class="thanks-text"> Thanks to <a href={`https://github.com/${thanks}`}>@{thanks}</a>{bonusThanks && <span> and <a href={`https://github.com/${bonusThanks}`}>@{bonusThanks}</a></span>}
      !</span>}
      
    </div>
  </div>

  {issue && (<a 
    class="github-link" 
    target="_blank" 
    rel="noopener noreferrer" 
    href={`https://github.com/FusionAuth/fusionauth-issues/issues/${issue}`}
  >
    #{issue}
  </a>)}

  {bonusIssue && (<a 
    class="github-link" 
    target="_blank" 
    rel="noopener noreferrer" 
    href={`https://github.com/FusionAuth/fusionauth-issues/issues/${bonusIssue}`}
  >
    #{bonusIssue}
  </a>)}
</div>


<style>
  @reference "tailwindcss";
  .issue-row a {
    @apply border-b-indigo-700 text-indigo-700
  }
  .issue-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: calc(var(--spacing)*8);
  }
  .issue-badge {
    flex-shrink: 0;
    width: 110px;
    text-align: center;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .issue-content {
    flex-grow: 1;
    color: var(--main-text-color);
  }
  .issue-content p {
    font-size: 1.15rem;
    line-height: 1.5;
  }

  .github-link {
    flex-shrink: 0;
    font-family: var(--code-font-family, monospace);
    font-size: 0.85rem;
    text-decoration: none;
    opacity: 0.7;
  }
  .github-link:hover {
    opacity: 1;
  }

  .thanks-text {
    font-style: italic;
    color: var(--dim-text-color, #666);
    font-size: 0.9rem;
  }


</style>