---
import {
  categories,
  getCategoryLabel,
} from "src/components/docs/release-notes/ReleaseNotes.astro";

export interface Props {
  issue?: string;
  bonusIssue?: string;
  thanks?: string;
  bonusThanks?: string;
  category: string;
  since?: string;
  resolvedIn?: string;
  viaIssue?: string;
}

const {
  issue,
  bonusIssue,
  thanks,
  since,
  bonusThanks,
  resolvedIn,
  viaIssue,
  category = "fix",
} = Astro.props as Props;

const label = getCategoryLabel(category);

const versionPart = resolvedIn
  ? `v-${resolvedIn.replaceAll('.', '-')}`
  : (since ? `since-${since.replaceAll('.', '-')}` : '');

const issuePart = issue
  ? `issue-${issue}`
  : (viaIssue ? `via-${viaIssue}` : '');

const thanksPart = thanks
  ? `thanks-${thanks.toLowerCase().replace(/[^a-z0-9]/g, '-')}`
  : '';

const baseId = [versionPart, category, issuePart, thanksPart]
  .filter(Boolean)
  .join('--');

/*
  Renders slot to raw string and runs a lightweight string hash
  to guarantee 100% unique, immutable IDs across builds (assuming no changes to release item content).
*/
const slotContent = await Astro.slots.render('default');
let hash = 0;
for (let i = 0; i < slotContent.length; i++) {
  hash = (hash << 5) - hash + slotContent.charCodeAt(i);
  hash |= 0;
}
const contentSlug = Math.abs(hash).toString(36).substring(0, 4);

const rowId = `${baseId}--${contentSlug}`;
---

<div
  id={rowId}
  class={`issue-row release-notes-item-${category}`}
>
  <a
    href={`#${rowId}`}
    class={`issue-badge badge-${category}`}
    aria-label="Permalink to this release note"
  >
    {label}
  </a>

  <div class="issue-content min-w-0">
    <div class="markdown-wrapper max-w-full overflow-x-auto">
      <slot />
      {
        resolvedIn && viaIssue && (
          <p class="markdown-wrapper">
            Resolved in version <a href={`#version-${resolvedIn.replaceAll('.', '-')}`}><code>{resolvedIn}</code></a> via
            {" "}
            <a
              target="_blank"
              rel="noopener noreferrer"
              href={`https://github.com/FusionAuth/fusionauth-issues/issues/${viaIssue}`}
            >
              #{viaIssue}
            </a>
            .
          </p>
        )
      }
      { since && <p class="thanks-text markdown-wrapper">Since: <a href={`#version-${since.replaceAll('.', '-')}`}><code>{since}</code></a></p>
      }
      {
        thanks && (
          <p class="thanks-text markdown-wrapper">
            Thanks to <a href={`https://github.com/${thanks}`}>@{thanks}</a>
            {bonusThanks && (
              <span>
                {" "}
                and{" "}
                <a href={`https://github.com/${bonusThanks}`}>@{bonusThanks}</a>
              </span>
            )}
            !
          </p>
        )
      }
    </div>
  </div>

  {
    issue && (
      <a
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
        href={`https://github.com/FusionAuth/fusionauth-issues/issues/${issue}`}
      >
        #{issue}
      </a>
    )
  }

  {
    bonusIssue && (
      <a
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
        href={`https://github.com/FusionAuth/fusionauth-issues/issues/${bonusIssue}`}
      >
        #{bonusIssue}
      </a>
    )
  }
</div>

<style>
  @reference "tailwindcss";

  .issue-row {
    @apply md:flex items-baseline 
      gap-4 mb-10 md:mb-4
      rounded-md transition-all duration-200;
    padding: 6px 8px;
    border: 2px solid transparent;
    scroll-margin-top: 5rem;
  }

  .issue-row:target {
    border-color: rgba(148, 163, 184, 0.5);
  }

  .issue-badge {
    @apply md:w-28 py-1 px-2 shrink-0 
      text-center text-xs font-bold 
      rounded-xs uppercase no-underline
      cursor-pointer select-none
      transition-transform duration-150 ease-out;
    transform-origin: left center;
  }

  .issue-badge:hover {
    @apply scale-105;
  }

  .issue-badge:active {
    @apply scale-95;
  }

  .issue-content {
    @apply grow;
  }

  .github-link {
    @apply shrink 
      text-sm no-underline opacity-70;
  }
  .github-link:hover {
    @apply opacity-100;
  }

  .thanks-text {
    @apply italic text-slate-600;
  }
</style>