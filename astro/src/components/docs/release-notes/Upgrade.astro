---
import { categories, getCategoryLabel } from 'src/components/docs/release-notes/ReleaseNotes.astro';

export interface Props {
}

const category = "upgrade"

export interface Props {}

const {} = Astro.props as Props;

const label = getCategoryLabel(category);
---
<div class={`issue-row release-notes-item-${category}`}>
  <span class={`issue-badge badge-${category}`}>
    {label}
  </span>

  <div class="issue-content">
    <div class="markdown-wrapper">
      <slot />
    </div>
  </div>
</div>


