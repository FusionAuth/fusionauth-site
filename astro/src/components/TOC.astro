---
import { parse } from 'node-html-parser';

const { maxDepth = 4, htmlContent = '' } = Astro.props;

// fully rendered HTML passed from the default layout
const root = parse(htmlContent);

const methodColors = {
  'GET': 'text-blue-600 dark:text-blue-400',
  'POST': 'text-green-600 dark:text-green-400',
  'PUT': 'text-orange-600 dark:text-orange-400',
  'PATCH': 'text-teal-600 dark:text-teal-400',
  'DELETE': 'text-red-600 dark:text-red-400'
};

let lastHeadingDepth = 2;

const rawHeadings = Array.from(root.querySelectorAll('h2, h3, h4, h5, h6, [data-toc-type="api"]'))
  .filter(h => h.id)
  .map(h => {
    const isApi = h.hasAttribute('data-toc-type');
    let depth;

    if (isApi) {
      depth = lastHeadingDepth;
    } else {
      depth = parseInt(h.tagName.substring(1), 10);
      lastHeadingDepth = depth;
    }

    return {
      id: h.id,
      text: isApi ? h.getAttribute('data-toc-text') : h.textContent.replace(/#/g, '').trim(),
      depth: depth,
      isApi: isApi,
      method: isApi ? h.getAttribute('data-toc-method') : null
    };
  });

let tocHtml = '';

if (rawHeadings.length > 0) {
  const minDepth = Math.min(...rawHeadings.map(h => h.depth));

  function buildTOCString(toc, currentDepth) {
    const headings = toc.filter(h => h.depth === currentDepth);
    if (headings.length === 0) return '';

    const isRoot = currentDepth === minDepth;
    const ulClass = isRoot ? "space-y-3 pt-5" : "space-y-3 ml-4 pt-3";
    const ulId = isRoot ? 'id="toc-list"' : '';

    let html = `<ul ${ulId} class="${ulClass}" data-widget="scroll-spy">`;

    headings.forEach((heading, idx) => {
      const nextHeading = headings[idx + 1];
      const startIndex = toc.findIndex(h => h.id === heading.id) + 1;
      const endIndex = nextHeading ? toc.findIndex(h => h.id === nextHeading.id) : toc.length;
      const subHeadings = toc.slice(startIndex, endIndex);

      html += `<li><div class="group" data-widget="scroll-spy-item">`;

      if (heading.isApi) {
        const colorClass = methodColors[heading.method] || 'text-yellow-600 dark:text-yellow-400';
        html += `<a href="#${heading.id}" class="block font-mono text-xs text-slate-600 dark:text-slate-400 dark:group-[.active]:text-indigo-400 dark:hover:text-slate-100 group-[.active]:text-indigo-600 hover:text-slate-900 transition-colors break-all">
                   <span class="font-bold pr-1.5 uppercase text-[10px] ${colorClass}">${heading.method}</span>
                   <span>${heading.text}</span>
                 </a>`;
      } else {
        html += `<a href="#${heading.id}" class="block font-medium text-slate-600 text-sm dark:text-slate-400 dark:group-[.active]:text-indigo-400 dark:hover:text-slate-100 group-[.active]:text-indigo-600 hover:text-slate-900 transition-colors">${heading.text}</a>`;
      }

      html += `</div>`;

      if (subHeadings.length > 0 && currentDepth < maxDepth) {
        html += buildTOCString(subHeadings, currentDepth + 1);
      }

      html += `</li>`;
    });

    html += `</ul>`;
    return html;
  }

  tocHtml = buildTOCString(rawHeadings, minDepth);
}
---
<nav id="toc-container" class="overflow-y-auto max-h-[calc(100vh-135px)]" set:html={tocHtml}></nav>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById('toc-container');
    if (!container) return;

    // headers from the DOM to track their position
    const headingElements = Array.from(document.querySelectorAll('h2[id], h3[id], h4[id], h5[id], h6[id], [data-toc-type="api"][id]'));
    const tocGroups = Array.from(container.querySelectorAll('[data-widget="scroll-spy-item"]'));

    if (headingElements.length === 0 || tocGroups.length === 0) return;

    let currentActiveId = null;
    let isTicking = false;

    const updateScrollSpy = () => {
      let activeHeading = headingElements[0];
      
      // find the last header that crossed the threshold
      for (let i = headingElements.length - 1; i >= 0; i--) {
        if (headingElements[i].getBoundingClientRect().top < 150) {
          activeHeading = headingElements[i];
          break;
        }
      }

      if (activeHeading && activeHeading.id !== currentActiveId) {
        currentActiveId = activeHeading.id;
        
        tocGroups.forEach(group => group.classList.remove('active'));
        
        const activeLink = container.querySelector(`a[href="#${activeHeading.id}"]`);
        if (activeLink) {
          const activeGroup = activeLink.closest('[data-widget="scroll-spy-item"]');
          if (activeGroup) {
            activeGroup.classList.add('active');
            activeGroup.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        }
      }
    };

    const onScroll = () => {
      if (!isTicking) {
        window.requestAnimationFrame(() => {
          updateScrollSpy();
          isTicking = false;
        });
        isTicking = true;
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    updateScrollSpy(); // initial check on load
  });
</script>