---
const { maxDepth = 4 } = Astro.props;
---

<nav id="toc-container"></nav>

<script define:vars={{ maxDepth }}>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById('toc-container');
    
    const rawHeadings = Array.from(document.querySelectorAll('h2, h3, h4, h5, h6'))
      .filter(h => h.id)
      .map(h => ({
        id: h.id,
        text: h.textContent.replace(/#/g, '').trim(),
        depth: parseInt(h.tagName.substring(1), 10)
      }));

    if (rawHeadings.length === 0) return;

    const minDepth = Math.min(...rawHeadings.map(h => h.depth));

    function buildTOC(toc, currentDepth) {
      const headings = toc.filter(h => h.depth === currentDepth);
      if (headings.length === 0) return null;

      const notFirstLevel = currentDepth > minDepth;

      const ul = document.createElement('ul');
      ul.setAttribute('data-widget', 'scroll-spy');
      
      ul.classList.add("space-y-3");
      if (notFirstLevel) {
        ul.classList.add("ml-4", "pt-3");
      } else {
        ul.classList.add("pt-5");
        ul.id = "toc-list";
      }

      headings.forEach((heading, idx) => {
        const nextHeading = headings[idx + 1];
        
        const startIndex = toc.findIndex(h => h.id === heading.id) + 1;
        const endIndex = nextHeading 
          ? toc.findIndex(h => h.id === nextHeading.id) 
          : toc.length;
          
        const subHeadings = toc.slice(startIndex, endIndex);

        const li = document.createElement('li');

        const div = document.createElement('div');
        div.className = "group";
        div.setAttribute('data-widget', 'scroll-spy-item');

        const a = document.createElement('a');
        a.href = "#" + heading.id;
        a.className = "block font-medium text-slate-600 text-sm dark:text-slate-400 dark:group-[.active]:text-indigo-400 dark:hover:text-slate-100 group-[.active]:text-indigo-600 hover:text-slate-900";
        a.textContent = heading.text;

        div.appendChild(a);
        li.appendChild(div);

        if (subHeadings.length > 0 && currentDepth < maxDepth) {
          const subUl = buildTOC(subHeadings, currentDepth + 1);
          if (subUl) {
            li.appendChild(subUl);
          }
        }

        ul.appendChild(li);
      });

      return ul;
    }

    const tocTree = buildTOC(rawHeadings, minDepth);
    if (tocTree) {
      container.appendChild(tocTree);
    }
  });
</script>