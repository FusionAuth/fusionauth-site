---
import { getCollection, render } from "astro:content";
import Layout from "/src/layouts/Article.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles");
  return entries.map(entry => {
    // 1. Remove the '/docs/' prefix from your generated ID
    // Example: '/docs/get-started/step-1' -> 'get-started/step-1'
    let slug = entry.id.replace(/^\/docs\//, '');

    // 2. Handle the root index page (/docs/)
    if (slug === 'index') {
      slug = undefined;
    }

    // Inside your .map()
    if (slug && slug.endsWith('/index')) {
      slug = slug.replace(/\/index$/, '');
    }

    return {
      params: { slug }, 
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---
<Layout frontmatter={entry.data} {headings} id={entry.id}
        excludeFromSearchIndex={entry.id?.endsWith('index.mdx') || entry.id?.endsWith('index.md')}>
  <Content/>
</Layout>
