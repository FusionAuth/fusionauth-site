---
import { getCollection, render } from "astro:content";
import Layout from "/src/layouts/Blog.astro";

export async function getStaticPaths() {
  const entries = await getCollection("blog");
  return entries.map(entry => {
    let slug = entry.id.replace(/^\/blog\//, '');

    if (slug === 'index') {
      slug = undefined;
    }

    if (slug && slug.endsWith('/index')) {
      slug = slug.replace(/\/index$/, '');
    }

    return {
      params: { slug }, 
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---
<Layout frontmatter={entry.data} {headings} id={entry.id}
        excludeFromSearchIndex={entry.id?.endsWith('index.mdx') || entry.id?.endsWith('index.md')}>
  <Content/>
</Layout>