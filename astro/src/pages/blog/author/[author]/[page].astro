---
import Layout from "../../../../layouts/BlogIndex.astro";
import { getStaticAuthorPaths, authors } from "src/tools/blog";

export async function getStaticPaths({ paginate }) {
  const paths = await getStaticAuthorPaths(paginate);
  
  // Only return paths for page 2 and beyond
  return paths.filter(p => p.params.page !== undefined);
}

const { page, authorName } = Astro.props;
const { author } = Astro.params;
---

<Layout
  title={"Posts authored by " + authorName}
  description={"FusionAuth Blog | " + authors[authorName]?.description ||
    `Read ${authorName}'s posts on mobile development and security practices.`}
  section="author"
  sectionTitle="Posts By"
  subjectRef={author}
  subjectName={authorName}
  page={page}
  isIndexPage={false} // This is guaranteed to be false here
  showCategories={true}
  personalLink={{
    text: authors[authorName]?.linkText,
    href: authors[authorName]?.linkUrl,
  }}
/>