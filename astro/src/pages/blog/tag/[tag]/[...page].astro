---
import Layout from '../../../../layouts/BlogIndex.astro';
import { getStaticTagPaths } from 'src/tools/blog';
import { startCase } from 'src/tools/string';

export async function getStaticPaths({ paginate }) {
  const allPaths = await getStaticTagPaths(paginate);

  const uniquePathsMap = new Map();

  allPaths.forEach(path => {
    const key = `${path.params.tag}/${path.params.page ?? 'index'}`;
    
    if (!uniquePathsMap.has(key)) {
      uniquePathsMap.set(key, path);
    }
  });

  return Array.from(uniquePathsMap.values());
}

const { page, tagName } = Astro.props;
const { tag } = Astro.params;

// If page.currentPage is 1, treat it as the index
const isIndexPage = page.currentPage === 1;
---

<Layout title={startCase(tagName) + " posts"}
        section="tag"
        sectionTitle="Tags"
        subjectRef={tag}
        subjectName={tagName}
        page={page}
        isIndexPage={isIndexPage}
        showCategories={true}/>