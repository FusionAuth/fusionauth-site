---
import { getCollection, render } from "astro:content";
import Layout from 'src/layouts/Docs.astro';
import { getDocNavContext } from '../../tools/docs';

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map(entry => {
    // 1. Remove the '/docs/' prefix from your generated ID
    // Example: '/docs/get-started/step-1' -> 'get-started/step-1'
    let slug = entry.id.replace(/^\/docs\//, '');

    // 2. Handle the root index page (/docs/)
    if (slug === 'index') {
      slug = undefined;
    }

    // Inside your .map()
    if (slug && slug.endsWith('/index')) {
      slug = slug.replace(/\/index$/, '');
    }

    return {
      params: { slug }, 
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const navContext = await getDocNavContext(entry.data.section);
let { Content, headings } = await render(entry);
---
<Layout frontmatter={entry.data} {headings} {navContext} disableTOC={entry.data.disableTOC || headings.length ===0}>
  <Content />
</Layout>
