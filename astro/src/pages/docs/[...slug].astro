---
import { getCollection, render } from "astro:content";
import Layout from '/src/layouts/Docs.astro';
import FullScreenLayout from '/src/layouts/FullScreenLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map(entry => {
    let slug = entry.id.replace(/^\/docs\//, '');

    // root index page (/docs/)
    if (slug === 'index') {
      slug = undefined;
    }

    if (slug && slug.endsWith('/index')) {
      slug = slug.replace(/\/index$/, '');
    }

    return {
      params: { slug }, 
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const isIndexPage = entry.id === 'index' || entry.id.endsWith('/index');
---
{entry.data.fullScreen ? (
  <FullScreenLayout frontmatter={entry.data}>
    <Content />
  </FullScreenLayout>
) : (
  <Layout frontmatter={entry.data} {headings} {isIndexPage} disableTOC={entry.data.disableTOC}>
    <Content />
  </Layout>
)}
