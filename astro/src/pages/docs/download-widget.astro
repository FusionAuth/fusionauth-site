---
import Layout from 'src/layouts/Blank.astro';
import DownloadWidget from 'src/components/download/DownloadWidget.astro';
import PostHog from 'src/components/PostHog.astro';

const title = 'Downloads';
const description = 'Download and cloud options';
const frontmatter = {};

// NOTE: This file is used by the Brochure site in Webflow via an iFrame. DO NOT DELETE THIS FILE!!!!!!!!
---
<Layout title={title} description={description} enableBaseParent={true} frontmatter={frontmatter}>
  <PostHog />
  <DownloadWidget kickstartEnabled={false} includeHostedOptions={true} includeKubernetes={true} includePackages={true} includeSandbox={true}/>
</Layout>
