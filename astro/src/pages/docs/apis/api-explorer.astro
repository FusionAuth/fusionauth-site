---
import '/src/css/style.css';
import Head from 'src/components/Head.astro';
import DocsNav from 'src/components/nav/DocsNav.astro';

const title = "FusionAuth API Explorer";
const description = "Interactive explorer for the FusionAuth API.";
---
<!DOCTYPE html>
<html lang="en" class="antialiased min-h-full">
  <Head title={title} description={description} />
  <style is:global>
    /* Hide the Astro dev toolbar on this page in local dev. No-op in
       production where the element isn't injected. */
    astro-dev-toolbar { display: none !important; }

    body { margin: 0; }

    .explorer-topbar {
      position: sticky;
      top: 65px;
      left: 0;
      right: 0;
      z-index: 40;
      height: 40px;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 16px;
      border-bottom: 1px solid #e2e8f0;
      background: #ffffff;
      font: 13px/1 ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      color: #475569;
    }
    html.dark .explorer-topbar {
      background: #0b1224;
      border-bottom-color: #1e293b;
      color: #94a3b8;
    }
    .explorer-topbar a {
      color: #f58320;
      text-decoration: none;
    }
    .explorer-topbar a:hover { text-decoration: underline; }
    .explorer-topbar .sep { color: #cbd5e1; }
    html.dark .explorer-topbar .sep { color: #334155; }
    .explorer-topbar .spacer { flex: 1; }

    .version-switcher {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .version-switcher label {
      white-space: nowrap;
      font-size: 12px;
      color: inherit;
    }
    .version-switcher select {
      height: 24px;
      padding: 0 24px 0 7px;
      font-size: 12px;
      border: 1px solid #cbd5e1;
      border-radius: 4px;
      background: #f8fafc;
      color: #0f172a;
      outline: none;
      cursor: pointer;
      appearance: auto;
    }
    html.dark .version-switcher select {
      border-color: #334155;
      background: #1e293b;
      color: #f1f5f9;
    }
    .version-switcher select:focus {
      border-color: #f58320;
      box-shadow: 0 0 0 2px rgba(245, 131, 32, 0.25);
    }
    .version-switcher .loading {
      font-size: 12px;
      color: inherit;
      opacity: 0.6;
    }
    .version-switcher .sep {
      font-size: 12px;
      color: #94a3b8;
      padding: 0 2px;
    }
    .download-label {
      font-size: 12px;
      color: inherit;
      white-space: nowrap;
    }
    .version-switcher a {
      font-size: 12px;
      color: #f58320;
      text-decoration: none;
      white-space: nowrap;
    }
    .version-switcher a:hover { text-decoration: underline; }

    /* ThemeSelector's MoonIcon hardcodes text-white (it lives in the dark
       docs nav by default). On our light topbar that's invisible, so we
       force the icon to inherit the topbar's foreground color. */
    .explorer-topbar fa-theme-selector svg { color: inherit !important; }

    #scalar-app { min-height: calc(100vh - 105px); }
  </style>
  <body class="antialiased">
    <DocsNav noSideNav={true} darkModeToggle={true} />
    <nav class="explorer-topbar">
      <span class="spacer"></span>
      <div class="version-switcher">
        <label for="version-select">Version:</label>
        <span id="version-loading" class="loading">Loading...</span>
        <select id="version-select" style="display:none" aria-label="API spec version"></select>
        <span class="sep">&middot;</span>
        <span class="download-label">Download:</span>
        <a id="download-yaml" href="#">YAML</a>
        <span class="sep">&middot;</span>
        <a id="download-json" href="#">JSON</a>
      </div>
      <span class="spacer"></span>
    </nav>

    <div id="scalar-app"></div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/@scalar/api-reference"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/js-yaml@4/dist/js-yaml.min.js"></script>
    <script is:inline>
      // Theme is owned entirely by ThemeSelector + Head.astro's inline script.
      // The single source of truth is `documentElement.classList.contains('dark')`.
      const customCss = `
        .darklight-reference { display: none !important; }
        .api-reference-toolbar { display: none !important; }
        .download-container { display: none !important; }

        .badge {
          display: inline-flex !important;
          align-items: center !important;
          padding: 5px 6px 3px !important;
          line-height: 1 !important;
        }

        aside.t-doc__sidebar {
          top: 105px !important;
          height: calc(100vh - 105px) !important;
        }

        #scalar-app [id] {
          scroll-margin-top: 105px !important;
        }

        #scalar-app input[type="text"],
        #scalar-app input[type="password"],
        #scalar-app input:not([type]) {
          border: 1px solid var(--scalar-border-color) !important;
          background: var(--scalar-background-2) !important;
          border-radius: 4px !important;
          padding: 4px 8px !important;
        }
        #scalar-app input[type="text"]:focus,
        #scalar-app input[type="password"]:focus,
        #scalar-app input:not([type]):focus {
          outline: none !important;
          border-color: var(--scalar-color-accent) !important;
          box-shadow: 0 0 0 2px rgba(245, 131, 32, 0.25) !important;
        }

        /* Set variables on body with html.dark/html:not(.dark) prefix so we
           outrank Scalar's own body.light-mode / body.dark-mode rules
           (specificity 0,1,2 vs Scalar's 0,1,1). */
        html:not(.dark) body, html.dark body {
          --scalar-color-accent: #f58320;
          --scalar-background-accent: #fff1e0;
        }
        html:not(.dark) body {
          --scalar-color-1: #0f172a;
          --scalar-color-2: #334155;
          --scalar-color-3: #64748b;
          --scalar-background-1: #ffffff;
          --scalar-background-2: #f8fafc;
          --scalar-background-3: #f1f5f9;
          --scalar-border-color: #e2e8f0;
          --scalar-sidebar-background-1: #f8fafc;
          --scalar-sidebar-color-1: #0f172a;
          --scalar-sidebar-color-2: #475569;
          --scalar-sidebar-border-color: #e2e8f0;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: #fff1e0;
        }
        html.dark body {
          --scalar-color-1: #f1f5f9;
          --scalar-color-2: #cbd5e1;
          --scalar-color-3: #94a3b8;
          --scalar-background-1: #0f172a;
          --scalar-background-2: #1e293b;
          --scalar-background-3: #334155;
          --scalar-border-color: #334155;
          --scalar-sidebar-background-1: #0b1224;
          --scalar-sidebar-color-1: #f1f5f9;
          --scalar-sidebar-color-2: #94a3b8;
          --scalar-sidebar-border-color: #1e293b;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: rgba(245, 131, 32, 0.12);
        }
      `;

      const isDark = () => document.documentElement.classList.contains('dark');

      const DEFAULT_URL = '/openapi.yaml';
      let activeUrl = DEFAULT_URL;

      // Scalar's updateConfiguration replaces (not merges) the config, so we
      // keep the full object around and pass it every time.
      const buildConfig = () => ({
        url: activeUrl,
        layout: 'modern',
        darkMode: isDark(),
        hideDarkModeToggle: true,
        agent: { disabled: true },
        customCss,
        metaData: { title: 'FusionAuth API Explorer' },
      });

      const scalar = Scalar.createApiReference('#scalar-app', buildConfig());

      // Re-skin Scalar when ThemeSelector flips html.dark.
      new MutationObserver(() => {
        scalar.updateConfiguration(buildConfig());
      }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });

      // Version switcher: populate from GitHub tags API, switch spec on change.
      const versionSelect  = document.getElementById('version-select');
      const versionLoading = document.getElementById('version-loading');

      const TAGS_URL = 'https://api.github.com/repos/FusionAuth/fusionauth-openapi/tags?per_page=100';
      const RAW_BASE = 'https://raw.githubusercontent.com/FusionAuth/fusionauth-openapi';

      fetch(TAGS_URL)
        .then(r => r.json())
        .then(tags => {
          // Current (built-in) spec always first
          const current = document.createElement('option');
          current.value = DEFAULT_URL;
          current.textContent = 'Current (latest)';
          versionSelect.appendChild(current);

          tags.forEach(tag => {
            const opt = document.createElement('option');
            opt.value = `${RAW_BASE}/${tag.name}/openapi.yaml`;
            opt.textContent = tag.name;
            versionSelect.appendChild(opt);
          });

          versionLoading.style.display = 'none';
          versionSelect.style.display = '';
        })
        .catch(() => {
          versionLoading.textContent = 'Version list unavailable';
        });

      // Download links use blobs to force download regardless of content-type.
      const downloadYaml = document.getElementById('download-yaml');
      const downloadJson = document.getElementById('download-json');

      async function triggerDownload(content, filename, type) {
        const blob = new Blob([content], { type });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.click();
        URL.revokeObjectURL(url);
      }

      downloadYaml.addEventListener('click', async (e) => {
        e.preventDefault();
        const resp = await fetch(activeUrl);
        const text = await resp.text();
        const filename = (activeUrl.split('/').pop() || 'openapi').replace(/\.json$/, '.yaml');
        triggerDownload(text, filename, 'application/yaml');
      });

      downloadJson.addEventListener('click', async (e) => {
        e.preventDefault();
        const resp = await fetch(activeUrl);
        const yamlText = await resp.text();
        const obj = jsyaml.load(yamlText);
        const json = JSON.stringify(obj, null, 2);
        const filename = (activeUrl.split('/').pop() || 'openapi').replace(/\.yaml$/, '.json');
        triggerDownload(json, filename, 'application/json');
      });

      versionSelect.addEventListener('change', () => {
        activeUrl = versionSelect.value;
        scalar.updateConfiguration(buildConfig());
      });
    </script>
  </body>
</html>
