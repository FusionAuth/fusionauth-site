---
import '/src/css/style.css';
import Head from 'src/components/Head.astro';
import DocsNav from 'src/components/nav/DocsNav.astro';

const title = "FusionAuth API Explorer";
const description = "Interactive explorer for the FusionAuth API.";

// Fetch the default OpenAPI spec at BUILD time
const LATEST_OPENAPI_URL = 'https://raw.githubusercontent.com/FusionAuth/fusionauth-openapi/main/openapi.yaml';
const response = await fetch(LATEST_OPENAPI_URL);
const bundledSpec = await response.text();
---
<!DOCTYPE html>
<html lang="en" class="antialiased min-h-full">
  <Head title={title} description={description} />
  <style is:global>
    astro-dev-toolbar { display: none !important; }
    body { margin: 0; }
    
    #scalar-app { min-height: calc(100vh - 65px); }
  </style>
  <body class="antialiased">
    <DocsNav noSideNav={true} darkModeToggle={true} />

    <div id="scalar-app"></div>

    <script is:inline src="/docs/vendor/scalar-api-reference.js"></script>
    <script is:inline src="/docs/vendor/js-yaml.min.js"></script>
    <script is:inline define:vars={{ bundledSpec }}>
      const customCss = `
        .darklight-reference { display: none !important; }
        .api-reference-toolbar { display: none !important; }
        .download-container { display: none !important; }

        h3 {
          font-family: monospace !important;
        }

        .badge {
          display: inline-flex !important;
          align-items: center !important;
          padding: 5px 6px 3px !important;
          line-height: 1 !important;
        }

        aside.t-doc__sidebar {
          top: 65px !important;
          height: calc(100vh - 65px) !important;
        }

        #scalar-app [id] {
          scroll-margin-top: 65px !important;
        }

        #scalar-app input[type="text"],
        #scalar-app input[type="password"],
        #scalar-app input:not([type]) {
          border: 1px solid var(--scalar-border-color) !important;
          background: var(--scalar-background-2) !important;
          border-radius: 4px !important;
          padding: 4px 8px !important;
        }
        #scalar-app input[type="text"]:focus,
        #scalar-app input[type="password"]:focus,
        #scalar-app input:not([type]):focus {
          outline: none !important;
          border-color: var(--scalar-color-accent) !important;
          box-shadow: 0 0 0 2px rgba(245, 131, 32, 0.25) !important;
        }

        html:not(.dark) body, html.dark body {
          --scalar-color-accent: #f58320;
          --scalar-background-accent: #fff1e0;
        }
        html:not(.dark) body {
          --scalar-color-1: #0f172a;
          --scalar-color-2: #334155;
          --scalar-color-3: #64748b;
          --scalar-background-1: #ffffff;
          --scalar-background-2: #f8fafc;
          --scalar-background-3: #f1f5f9;
          --scalar-border-color: #e2e8f0;
          --scalar-sidebar-background-1: #f8fafc;
          --scalar-sidebar-color-1: #0f172a;
          --scalar-sidebar-color-2: #475569;
          --scalar-sidebar-border-color: #e2e8f0;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: #fff1e0;
        }
        html.dark body {
          --scalar-color-1: #f1f5f9;
          --scalar-color-2: #cbd5e1;
          --scalar-color-3: #94a3b8;
          --scalar-background-1: #0f172a;
          --scalar-background-2: #1e293b;
          --scalar-background-3: #334155;
          --scalar-border-color: #334155;
          --scalar-sidebar-background-1: #0b1224;
          --scalar-sidebar-color-1: #f1f5f9;
          --scalar-sidebar-color-2: #94a3b8;
          --scalar-sidebar-border-color: #1e293b;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: rgba(245, 131, 32, 0.12);
        }
      `;

      const isDark = () => document.documentElement.classList.contains('dark');

      const buildConfig = () => ({
        layout: 'modern',
        darkMode: isDark(),
        hideDarkModeToggle: true,
        agent: { disabled: true },
        customCss,
        metaData: { title: 'FusionAuth API Explorer' },
        spec: { content: bundledSpec } 
      });

      const scalar = Scalar.createApiReference('#scalar-app', buildConfig());

      new MutationObserver(() => {
        scalar.updateConfiguration(buildConfig());
      }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });

      function triggerDownload(content, filename, type) {
        const blob = new Blob([content], { type });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.click();
        URL.revokeObjectURL(url);
      }

      const scalarObserver = new MutationObserver(() => {
        const containerId = 'custom-inline-downloads';
        if (document.getElementById(containerId)) return;

        const title = document.querySelector('#scalar-app h1');
        if (title) {
          const dlDiv = document.createElement('div');
          dlDiv.id = containerId;
          
          dlDiv.style.cssText = `
            display: inline-flex;
            align-items: center;
            gap: 12px;
            margin-top: 16px;
            padding: 8px 14px;
            background: var(--scalar-background-2);
            border: 1px solid var(--scalar-border-color);
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
          `;
          
          dlDiv.innerHTML = `
            <span style="color: var(--scalar-color-3)">Download OpenAPI Spec:</span>
            <a href="#" id="dl-yaml" style="color: var(--scalar-color-accent); text-decoration: none;">YAML</a>
            <span style="color: var(--scalar-border-color)">&middot;</span>
            <a href="#" id="dl-json" style="color: var(--scalar-color-accent); text-decoration: none;">JSON</a>
          `;
          
          title.parentNode.insertBefore(dlDiv, title.nextSibling);

          document.getElementById('dl-yaml').addEventListener('click', (e) => {
            e.preventDefault();
            triggerDownload(bundledSpec, 'openapi.yaml', 'application/yaml');
          });

          document.getElementById('dl-json').addEventListener('click', (e) => {
            e.preventDefault();
            const obj = jsyaml.load(bundledSpec);
            const json = JSON.stringify(obj, null, 2);
            triggerDownload(json, 'openapi.json', 'application/json');
          });
        }
      });

      // Observe the app container to catch the render cycle
      scalarObserver.observe(document.getElementById('scalar-app'), { 
        childList: true, 
        subtree: true 
      });
    </script>
  </body>
</html>