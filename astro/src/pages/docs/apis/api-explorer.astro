---
import '/src/css/style.css';
import Head from 'src/components/Head.astro';
import ThemeSelector from 'src/components/ThemeSelector.astro';

const title = "FusionAuth API Explorer";
const description = "Interactive explorer for the FusionAuth API.";
---
<!DOCTYPE html>
<html lang="en" class="antialiased min-h-full">
  <Head title={title} description={description} />
  <style is:global>
    /* Hide the Astro dev toolbar on this page in local dev. No-op in
       production where the element isn't injected. */
    astro-dev-toolbar { display: none !important; }

    body { margin: 0; padding-top: 40px; }

    .explorer-prose {
      max-width: 800px;
      margin: 0 auto;
      padding: 32px 24px 40px;
      font: 15px/1.6 ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      color: #1e293b;
    }
    html.dark .explorer-prose { color: #cbd5e1; }

    .explorer-prose h1 {
      font-size: 1.875rem;
      font-weight: 700;
      margin: 0 0 1rem;
      color: #0f172a;
    }
    html.dark .explorer-prose h1 { color: #f1f5f9; }

    .explorer-prose h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 1.75rem 0 0.5rem;
      color: #0f172a;
    }
    html.dark .explorer-prose h2 { color: #f1f5f9; }

    .explorer-prose h3 {
      font-size: 1rem;
      font-weight: 600;
      margin: 1.25rem 0 0.4rem;
      color: #0f172a;
    }
    html.dark .explorer-prose h3 { color: #f1f5f9; }

    .explorer-prose p { margin: 0.5rem 0; }

    .explorer-prose a { color: #f58320; text-decoration: none; }
    .explorer-prose a:hover { text-decoration: underline; }

    .explorer-prose ul {
      margin: 0.5rem 0 0.5rem 1.5rem;
      padding: 0;
      list-style: disc;
    }
    .explorer-prose li { margin: 0.25rem 0; }

    .explorer-prose code {
      font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
      font-size: 0.875em;
      background: #f1f5f9;
      border-radius: 3px;
      padding: 1px 5px;
    }
    html.dark .explorer-prose code {
      background: #1e293b;
      color: #e2e8f0;
    }

    .explorer-prose .inline-field {
      font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
      font-size: 0.875em;
      background: #f1f5f9;
      border: 1px solid #e2e8f0;
      border-radius: 3px;
      padding: 1px 6px;
    }
    html.dark .explorer-prose .inline-field {
      background: #1e293b;
      border-color: #334155;
      color: #e2e8f0;
    }

    .explorer-prose .aside {
      border-left: 4px solid #f59e0b;
      background: #fffbeb;
      border-radius: 0 4px 4px 0;
      padding: 12px 16px;
      margin: 1rem 0;
      font-size: 0.9375rem;
    }
    html.dark .explorer-prose .aside {
      background: #1c1a0e;
      border-left-color: #d97706;
    }
    .explorer-prose .aside strong { color: #92400e; }
    html.dark .explorer-prose .aside strong { color: #fcd34d; }

    .explorer-prose img {
      max-width: 100%;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      margin: 1rem 0;
    }
    html.dark .explorer-prose img { border-color: #334155; }

    .explorer-topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      height: 40px;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 16px;
      border-bottom: 1px solid #e2e8f0;
      background: #ffffff;
      font: 13px/1 ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      color: #475569;
    }
    html.dark .explorer-topbar {
      background: #0b1224;
      border-bottom-color: #1e293b;
      color: #94a3b8;
    }
    .explorer-topbar a {
      color: #f58320;
      text-decoration: none;
    }
    .explorer-topbar a:hover { text-decoration: underline; }
    .explorer-topbar .sep { color: #cbd5e1; }
    html.dark .explorer-topbar .sep { color: #334155; }
    .explorer-topbar .spacer { flex: 1; }

    /* ThemeSelector's MoonIcon hardcodes text-white (it lives in the dark
       docs nav by default). On our light topbar that's invisible, so we
       force the icon to inherit the topbar's foreground color. */
    .explorer-topbar fa-theme-selector svg { color: inherit !important; }

    #scalar-app { min-height: calc(100vh - 40px); }
  </style>
  <body class="antialiased">
    <nav class="explorer-topbar" aria-label="Breadcrumb">
      <a href="/docs/">FusionAuth Docs</a>
      <span class="sep">/</span>
      <a href="/docs/apis/">APIs</a>
      <span class="sep">/</span>
      <span>API Explorer</span>
      <span class="spacer"></span>
      <ThemeSelector />
    </nav>
    <div class="explorer-prose">
      <h1>API Explorer</h1>
      <p>This tool uses the <a href="https://github.com/fusionauth/fusionauth-openapi">FusionAuth OpenAPI specification</a> to let you explore the APIs FusionAuth offers.</p>
      <p>This is designed to be used against a local FusionAuth instance.</p>

      <h2>Prerequisites</h2>
      <p>FusionAuth can be locally installed or used as a SaaS solution. This API explorer is useful only for a local installation.</p>
      <p>Please <a href="/docs/get-started/download-and-install">install FusionAuth locally</a> to use the explorer below.</p>
      <p>After you install FusionAuth, make sure you have <a href="/docs/apis/authentication#managing-api-keys">created an API key with the correct permissions</a>. This API key will not be stored.</p>

      <h2>Configuration</h2>
      <p>Click the <span class="inline-field">Authenticate</span> button in the explorer to add the FusionAuth API key you created above. You will need to do this every time you reload the page.</p>

      <h3>In-Browser API Calls</h3>
      <p>If you want to use the in-browser API explorer, you have to configure CORS on the local FusionAuth instance. Doing so is not required if using the example curl commands to call the API from the command line.</p>
      <p>To set up CORS:</p>
      <ul>
        <li>Log in to your FusionAuth administrative user interface</li>
        <li>Navigate to <span class="inline-field">Settings &rarr; System</span></li>
        <li>Enable <span class="inline-field">CORS</span></li>
        <li>Update <span class="inline-field">Allowed headers</span> to include <code>authorization</code>, <code>accept</code>, and <code>content-type</code></li>
        <li>Check all the <span class="inline-field">Allowed methods</span></li>
        <li>Set <span class="inline-field">Allowed origins</span> to your origin, or <code>*</code> to allow any origin</li>
      </ul>
      <div class="aside">
        <strong>Caution:</strong> Do not run your production FusionAuth instance with CORS configured to be this open. For development and exploration, this is acceptable.
      </div>
      <img src="/img/docs/apis/cors-settings-api-explorer.png" alt="CORS settings for the API explorer" />
    </div>

    <div id="scalar-app"></div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/@scalar/api-reference"></script>
    <script is:inline>
      // Theme is owned entirely by ThemeSelector + Head.astro's inline script.
      // The single source of truth is `documentElement.classList.contains('dark')`.
      const customCss = `
        .darklight-reference { display: none !important; }
        .api-reference-toolbar { display: none !important; }

        aside.t-doc__sidebar {
          top: 40px !important;
          height: calc(100vh - 40px) !important;
        }

        #scalar-app input[type="text"],
        #scalar-app input[type="password"],
        #scalar-app input:not([type]) {
          border: 1px solid var(--scalar-border-color) !important;
          background: var(--scalar-background-2) !important;
          border-radius: 4px !important;
          padding: 4px 8px !important;
        }
        #scalar-app input[type="text"]:focus,
        #scalar-app input[type="password"]:focus,
        #scalar-app input:not([type]):focus {
          outline: none !important;
          border-color: var(--scalar-color-accent) !important;
          box-shadow: 0 0 0 2px rgba(245, 131, 32, 0.25) !important;
        }

        /* Set variables on body with html.dark/html:not(.dark) prefix so we
           outrank Scalar's own body.light-mode / body.dark-mode rules
           (specificity 0,1,2 vs Scalar's 0,1,1). */
        html:not(.dark) body, html.dark body {
          --scalar-color-accent: #f58320;
          --scalar-background-accent: #fff1e0;
        }
        html:not(.dark) body {
          --scalar-color-1: #0f172a;
          --scalar-color-2: #334155;
          --scalar-color-3: #64748b;
          --scalar-background-1: #ffffff;
          --scalar-background-2: #f8fafc;
          --scalar-background-3: #f1f5f9;
          --scalar-border-color: #e2e8f0;
          --scalar-sidebar-background-1: #f8fafc;
          --scalar-sidebar-color-1: #0f172a;
          --scalar-sidebar-color-2: #475569;
          --scalar-sidebar-border-color: #e2e8f0;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: #fff1e0;
        }
        html.dark body {
          --scalar-color-1: #f1f5f9;
          --scalar-color-2: #cbd5e1;
          --scalar-color-3: #94a3b8;
          --scalar-background-1: #0f172a;
          --scalar-background-2: #1e293b;
          --scalar-background-3: #334155;
          --scalar-border-color: #334155;
          --scalar-sidebar-background-1: #0b1224;
          --scalar-sidebar-color-1: #f1f5f9;
          --scalar-sidebar-color-2: #94a3b8;
          --scalar-sidebar-border-color: #1e293b;
          --scalar-sidebar-color-active: #f58320;
          --scalar-sidebar-background-active: rgba(245, 131, 32, 0.12);
        }
      `;

      const isDark = () => document.documentElement.classList.contains('dark');

      // Scalar's updateConfiguration replaces (not merges) the config, so we
      // keep the full object around and pass it every time.
      const buildConfig = () => ({
        url: '/openapi.yaml',
        layout: 'modern',
        darkMode: isDark(),
        hideDarkModeToggle: true,
        agent: { disabled: true },
        customCss,
        metaData: { title: 'FusionAuth API Explorer' },
      });

      const scalar = Scalar.createApiReference('#scalar-app', buildConfig());

      // Re-skin Scalar when ThemeSelector flips html.dark.
      new MutationObserver(() => {
        scalar.updateConfiguration(buildConfig());
      }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });
    </script>
  </body>
</html>
