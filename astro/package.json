{
	"name": "fusionauth-site",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "npm run generate-code-snippets && astro dev --port 3000",
		"start": "npm run build && astro preview",
		"build": "npm run generate-code-snippets && astro build",
		"dev-build": "npm run generate-code-snippets && DEV=true astro build",
		"generate-code-snippets": "bash ../src/scripts/generate-code-snippets.sh",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint",
		"lint-pr": "node ../src/scripts/lint-recent-files.mjs",
		"test-code-examples": "bash ../src/scripts/test-code-examples.sh",
		"validate-code-snippets": "out=$(npx --yes bluehawk check --plugin bluehawk-languages.js --ignore 'node_modules' --ignore '.gitignore' --ignore '.DS_Store' --ignore 'package*.json' --ignore '*.lock' --ignore 'repositoryUrl.txt' --ignore 'tests' --ignore 'LICENSE' --ignore 'SECURITY.md' src/code-example-repositories 2>&1); status=$?; printf '%s\\n' \"$out\" | grep -v 'parsed file' | grep -v 'found binary file'; exit $status"
	},
	"dependencies": {
		"@astro-community/astro-embed-youtube": "^0.5.10",
		"@astrojs/markdown-remark": "^7.2.1",
		"@astrojs/mdx": "^7.0.3",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/view": "^6.39.16",
		"@docsearch/css": "^4.6.2",
		"@docsearch/js": "^4.6.2",
		"@emnapi/runtime": "^1.9.2",
		"@fusionauth/react-sdk": "^2.6.0",
		"@iconify-json/fa7-regular": "^1.2.3",
		"@iconify-json/fa7-solid": "^1.2.4",
		"@scalar/astro": "^0.4.9",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"astro": "^7.1.3",
		"astro-iconset": "^0.0.4",
		"astro-index-pages": "file:src/integrations/astro-index-pages",
		"astro-link-validator": "github:rodgtr1/astro-link-validator",
		"codemirror": "^6.0.2",
		"es-toolkit": "1.46.1",
		"jose": "^6.2.3",
		"js-yaml": "^4.1.1",
		"jsonpath-plus": "^10.4.0",
		"jsonwebtoken-esm": "^1.0.5",
		"marked": "^17.0.3",
		"marked-plaintify": "^1.1.1",
		"mermaid": "^11.14.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-mdx": "^3.1.1",
		"semver": "^7.7.4",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/parser": "^8.56.1",
		"bluehawk-plugin-git": "^1.0.0",
		"cheerio": "^1.2.0",
		"eslint": "^10.2.0",
		"eslint-mdx": "^3.7.0",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-mdx": "^3.7.0",
		"globals": "^17.4.0",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.56.1",
		"yaml": "^2.9.0"
	},
	"overrides": {
		"astro-link-validator": {
			"astro": "$astro"
		},
		"@scalar/astro": {
			"astro": "$astro"
		}
	}
}
